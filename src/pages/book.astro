---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const pageCollection = await getCollection("pageBook");
const page = pageCollection[0]?.data;
---

<PageLayout
  title={page?.metaTitle ?? "Book | Millie The Hut"}
  description={page?.metaDescription ?? "Check availability and make a booking enquiry for Millie The Hut — luxury shepherd's hut glamping in the Welsh Marches."}
>
  <!-- Page Header -->
  <section class="page-header">
    <Container>
      <div class="page-header__content" data-reveal="slide-up">
        <h1 class="page-header__title">{page?.pageTitle ?? "Booking Enquiry"}</h1>
        <p class="page-header__desc">{page?.pageDescription ?? "Please check our availability calendar, and make a booking enquiry using the form below."}</p>
        <p class="page-header__rate-link"><a href="#rates-heading">See our rate card below &darr;</a></p>
      </div>
    </Container>
  </section>

  <!-- Booking Grid -->
  <section class="section">
    <Container>
      <div class="booking-grid">

        <!-- Booking Form -->
        <div class="form-wrap" data-reveal="slide-up">
          {Astro.url.searchParams.get("success") === "true" && (
            <p class="form-success" role="alert">Thanks for your enquiry — we'll be in touch shortly to confirm availability.</p>
          )}
          <form class="booking-form" name="booking" method="POST" action="/book/?success=true" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="booking" />
            <p class="sr-only" aria-hidden="true">
              <label>Don't fill this in: <input name="bot-field" /></label>
            </p>

            <div class="form-group">
              <label class="form-label" for="booking-email">Email address <span aria-hidden="true">*</span></label>
              <input class="form-input" type="email" id="booking-email" name="email" required autocomplete="email" placeholder="jane@example.com" />
            </div>

            <div class="form-group">
              <label class="form-label" for="booking-dates">Dates you would like to book <span aria-hidden="true">*</span></label>
              <input class="form-input" type="text" id="booking-dates" name="dates" required placeholder="e.g. 14–17 June 2026" />
            </div>

            <div class="form-group">
              <label class="form-label" for="booking-comments">Any requests / comments</label>
              <textarea class="form-input form-textarea" id="booking-comments" name="comments" rows="5" placeholder="Anything else you'd like us to know?"></textarea>
            </div>

            <button class="form-submit" type="submit">Send Enquiry &rarr;</button>
          </form>
        </div>

        <!-- Availability Widget Sidebar -->
        <aside class="booking-sidebar" data-reveal="fade">
          <div class="widget-card">
            <h2 class="widget-card__title">Availability</h2>
            <div class="widget-card__embed" id="bookalet-widget">
              <script src="https://widgets.bookalet.co.uk/publish.js" data-bookalet="b25b1c2d-43da-4f9a-85cd-921af5cfd74a" data-property="25256" is:inline></script>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Rate Card -->
  <section class="section section--rate-card" aria-labelledby="rates-heading">
    <Container>
      <h2 class="section__heading" id="rates-heading">Rate Card <span class="section__heading-sub">(per night)</span></h2>

      <div class="rate-table-wrap" data-reveal="slide-up">
        <table class="rate-table">
          <thead>
            <tr>
              <th class="rate-table__th rate-table__th--dates">Dates</th>
              <th class="rate-table__th">Sun – Thur</th>
              <th class="rate-table__th">Fri – Sat</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="rate-table__season">
                <strong>Low Season</strong>
                <span>5 Jan – 29 Mar &amp; 30 Oct – 20 Dec*</span>
              </td>
              <td class="rate-table__price">&pound;120</td>
              <td class="rate-table__price">&pound;145</td>
            </tr>
            <tr>
              <td class="rate-table__season">
                <strong>Mid Season</strong>
                <span>30 Mar – 30 Jun &amp; 7 Sept – 29 Oct*</span>
              </td>
              <td class="rate-table__price">&pound;130</td>
              <td class="rate-table__price">&pound;160</td>
            </tr>
            <tr>
              <td class="rate-table__season">
                <strong>High Season</strong>
                <span>1 July – 6 Sept*</span>
              </td>
              <td class="rate-table__price">&pound;150</td>
              <td class="rate-table__price">&pound;175</td>
            </tr>
            <tr>
              <td class="rate-table__season">
                <strong>Peak Season</strong>
                <span>Val Day, Easter 3–6 Apr, Bank Hol w/ends &amp; 21 Dec 2026 – 3 Jan 2027</span>
              </td>
              <td class="rate-table__price">&pound;160**</td>
              <td class="rate-table__price">&pound;190</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="rate-notes" data-reveal="fade">
        <p>*Excl Peak Season Dates inc Bank Hols.</p>
        <p>** Bank Hol Sundays &pound;180</p>
        <p>Min stay – 2 nights midweek, 3 nights weekends (except low season, 2 nights). Booking start days Mon, Wed, Fri (may be some flexibility, please enquire).</p>
      </div>
    </Container>
  </section>
</PageLayout>

<style>
  /* ─── Page Header ─── */
  .page-header {
    padding: var(--space-5xl) 0 calc(var(--section-padding) / 2);
    background: var(--color-bg-white);
  }

  .page-header__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 70px);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .page-header__desc {
    font-family: var(--font-sans);
    font-size: clamp(18px, 2.5vw, 25px);
    color: var(--color-text-muted);
    max-width: 48ch;
    line-height: var(--leading-relaxed);
    letter-spacing: var(--tracking-tight);
  }

  .page-header__rate-link {
    margin-top: var(--space-sm);
  }

  .page-header__rate-link a {
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.3vw, 18px);
    color: var(--color-primary);
    font-weight: var(--weight-medium);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .page-header__rate-link a:hover {
    opacity: 0.7;
  }

  /* ─── Sections ─── */
  .section {
    padding: calc(var(--section-padding) / 2) 0 var(--section-padding);
    background: var(--color-bg-white);
  }

  .section--rate-card {
    padding: var(--section-padding) 0;
  }

  .section__heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 50px);
    font-weight: var(--weight-bold);
    text-align: center;
    margin-bottom: var(--space-3xl);
    letter-spacing: var(--tracking-tight);
  }

  .section__heading-sub {
    font-weight: var(--weight-normal);
    font-size: 0.6em;
    color: var(--color-text-muted);
  }

  /* ─── Booking Grid ─── */
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* ─── Form ─── */
  .form-success {
    background: var(--color-cta);
    color: var(--color-text);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-xl);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
  }
  .booking-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .form-label {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.2vw, 18px);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .form-label span {
    color: var(--color-primary);
  }

  .form-input {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.2vw, 18px);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--ease-out);
    appearance: none;
  }

  .form-input:focus {
    border-color: var(--color-primary);
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .form-textarea {
    resize: vertical;
    min-height: 10rem;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.4rem;
    padding: var(--space-md) var(--space-2xl);
    background: var(--color-cta);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: var(--weight-bold);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    letter-spacing: var(--tracking-tight);
  }

  .form-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  /* ─── Sidebar ─── */
  .booking-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .widget-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
  }

  .widget-card__title {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .widget-card__embed {
    min-height: 300px;
  }

  /* ─── Rate Table ─── */
  .rate-table-wrap {
    max-width: 48rem;
    margin-inline: auto;
    overflow-x: auto;
  }

  .rate-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.3vw, 17px);
    letter-spacing: var(--tracking-tight);
  }

  .rate-table__th {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.5vw, 18px);
    font-weight: var(--weight-bold);
    text-align: center;
    padding: var(--space-md) var(--space-lg);
    border-bottom: 2px solid var(--color-text);
    white-space: nowrap;
  }

  .rate-table__th--dates {
    text-align: left;
    width: 45%;
  }

  .rate-table__season {
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
    vertical-align: top;
  }

  .rate-table__season strong {
    display: block;
    font-weight: var(--weight-bold);
    margin-bottom: 2px;
  }

  .rate-table__season span {
    font-size: clamp(13px, 1.1vw, 15px);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .rate-table__price {
    text-align: center;
    padding: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
    font-weight: var(--weight-semibold);
    font-size: clamp(16px, 1.5vw, 20px);
    vertical-align: middle;
  }

  /* ─── Rate Notes ─── */
  .rate-notes {
    max-width: 48rem;
    margin-inline: auto;
    margin-top: var(--space-2xl);
    text-align: center;
  }

  .rate-notes p {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.2vw, 16px);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-sm);
    letter-spacing: var(--tracking-tight);
  }

  .rate-notes p:last-child {
    margin-bottom: 0;
    margin-top: var(--space-md);
  }

  @media (min-width: 64rem) {
    .booking-grid {
      grid-template-columns: 1.4fr 1fr;
    }
  }
</style>

<style is:global>
  /* ─── Bookalet Widget Theme Overrides ─── */
  #bookalet-widget .bk-calendar {
    font-family: 'Inter', system-ui, sans-serif !important;
  }
  #bookalet-widget .bk-calendar-header {
    background-color: #000000 !important;
    color: #ffffff !important;
    font-family: 'Playfair Display', Georgia, serif !important;
  }
  #bookalet-widget .bk-calendar td.available {
    background-color: #ABE3C4 !important;
    color: #000000 !important;
  }
  #bookalet-widget .bk-calendar td.unavailable {
    background-color: #f4efe8 !important;
    color: #999999 !important;
  }
</style>
