---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getCollection } from "astro:content";

const pageCollection = await getCollection("pageLocation");
const page = pageCollection[0]?.data;

const allAttractions = await getCollection("attractions");
const sortedAttractions = allAttractions.sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title={page?.metaTitle ?? "Location | Millie The Hut"}
  description={page?.metaDescription}
>
  <!-- Page Header -->
  <section class="page-header">
    <Container>
      <div class="page-header__content" data-reveal="slide-up">
        {page?.pageEyebrow && <p class="page-header__eyebrow">{page.pageEyebrow}</p>}
        <h1 class="page-header__title">{page?.pageTitle ?? "Location"}</h1>
        {page?.pageDescription && <p class="page-header__desc">{page.pageDescription}</p>}
      </div>
    </Container>
  </section>

  <!-- Getting there -->
  <section class="section">
    <Container>
      <div class="getting-there-grid">
        <div data-reveal="slide-up">
          <SectionHeading
            label="Getting Here"
            title={page?.gettingThereHeading ?? "Getting here"}
          />
          {page?.gettingThereParagraphs?.map((para) => (
            <p>{para}</p>
          ))}
          <div class="getting-there__actions">
            <Button href="/book/" size="md">Book Your Stay</Button>
          </div>
        </div>
        {page?.journeyTimes && page.journeyTimes.length > 0 && (
          <aside class="distances-card" data-reveal="fade">
            <h2 class="distances-card__title">Journey times</h2>
            <ul class="distances-list" role="list">
              {page.journeyTimes.map((item) => (
                <li class="distances-list__item">
                  <span class="distances-list__place">{item.place}</span>
                  <span class="distances-list__time">{item.time}</span>
                </li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </Container>
  </section>

  <!-- Map placeholder -->
  <section class="map-section" aria-label="Map location">
    <div class="map-placeholder">
      <Container>
        <div class="map-placeholder__inner">
          <p class="map-placeholder__text">Interactive map coming soon</p>
          {page?.pageEyebrow && (
            <p class="map-placeholder__sub">{page.pageEyebrow}</p>
          )}
        </div>
      </Container>
    </div>
  </section>

  <!-- Attractions -->
  {sortedAttractions.length > 0 && (
    <section class="section" aria-labelledby="attractions-heading">
      <Container>
        <SectionHeading
          label="Explore"
          title={page?.attractionsSectionHeading ?? "What's nearby"}
          description={page?.attractionsSectionDescription}
          align="center"
        />
        <div class="attractions-grid" data-reveal-stagger>
          {sortedAttractions.map((attraction) => (
            <article class="attraction-card">
              <div class="attraction-card__header">
                <h3 class="attraction-card__name">{attraction.data.name}</h3>
                <span class="attraction-card__distance">{attraction.data.distance}</span>
              </div>
              <p class="attraction-card__desc">{attraction.data.description}</p>
            </article>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- The landscape -->
  {(page?.landscapeHeading || page?.landscapeParagraphs?.length) && (
    <section class="section section--surface" aria-labelledby="landscape-heading">
      <Container narrow>
        <SectionHeading
          label="The Landscape"
          title={page?.landscapeHeading ?? "The Area"}
          align="center"
        />
        <div class="prose" data-reveal="slide-up">
          {page?.landscapeParagraphs?.map((para) => (
            <p>{para}</p>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- CTA -->
  {(page?.ctaHeading || page?.ctaDescription) && (
    <section class="cta-banner">
      <Container>
        <div class="cta-banner__inner" data-reveal="slide-up">
          {page.ctaHeading && <h2 class="cta-banner__title">{page.ctaHeading}</h2>}
          {page.ctaDescription && <p class="cta-banner__desc">{page.ctaDescription}</p>}
          <Button href="/book/" size="lg">Book Now</Button>
        </div>
      </Container>
    </section>
  )}
</PageLayout>

<style>
  .page-header {
    background: var(--color-surface);
    padding: var(--space-5xl) 0 var(--section-padding);
  }

  .page-header__eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  .page-header__title {
    margin-bottom: var(--space-md);
  }

  .page-header__desc {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    max-width: 52ch;
    font-style: italic;
    font-family: var(--font-serif);
    line-height: var(--leading-relaxed);
  }

  .section {
    padding: var(--section-padding) 0;
  }

  .section--surface {
    background: var(--color-surface);
  }

  .getting-there-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .getting-there-grid p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .getting-there__actions {
    margin-top: var(--space-xl);
  }

  .distances-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
  }

  .distances-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .distances-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .distances-list__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border-light);
    font-size: var(--text-sm);
  }

  .distances-list__item:last-child {
    border-bottom: none;
  }

  .distances-list__place {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  .distances-list__time {
    color: var(--color-text-muted);
  }

  .map-section {
    background: var(--color-surface-alt);
  }

  .map-placeholder {
    height: 20rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .map-placeholder__inner {
    text-align: center;
  }

  .map-placeholder__text {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
    font-style: italic;
    max-width: none;
  }

  .map-placeholder__sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    opacity: 0.6;
    max-width: none;
  }

  .attractions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .attraction-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .attraction-card:hover {
    border-color: var(--color-primary);
  }

  .attraction-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-sm);
    gap: var(--space-md);
  }

  .attraction-card__name {
    font-size: var(--text-lg);
  }

  .attraction-card__distance {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .attraction-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  .prose p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-relaxed);
    font-size: var(--text-lg);
    max-width: none;
  }

  .cta-banner {
    background: var(--color-text);
    color: var(--color-text-inverse);
    padding: var(--section-padding) 0;
  }

  .cta-banner__inner {
    text-align: center;
  }

  .cta-banner__title {
    color: var(--color-text-inverse);
    margin-bottom: var(--space-md);
  }

  .cta-banner__desc {
    font-size: var(--text-lg);
    opacity: 0.8;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
    font-family: var(--font-serif);
    font-style: italic;
  }

  @media (min-width: 48rem) {
    .attractions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .getting-there-grid {
      grid-template-columns: 1.3fr 1fr;
    }
    .attractions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
