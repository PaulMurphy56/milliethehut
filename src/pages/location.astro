---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const pageCollection = await getCollection("pageLocation");
const page = pageCollection[0]?.data;
---

<PageLayout
  title={page?.metaTitle ?? "Local Area | Millie The Hut"}
  description={page?.metaDescription}
>
  <!-- Inner Hero -->
  <section class="inner-hero">
    <Container>
      <div class="inner-hero__grid">
        <div class="inner-hero__text">
          <h1 class="inner-hero__title">{page?.pageTitle ?? "Local Area"}</h1>
          <p class="inner-hero__subtitle">{page?.pageDescription ?? "Millie The Hut sits quietly on the England/Wales border, amidst wild countryside, cute towns, and open skies."}</p>
          <p class="inner-hero__jump">Jump to:</p>
          <nav class="inner-hero__links" aria-label="Page sections">
            <a href="#the-area" class="inner-hero__link">The Area</a>
            <a href="#activities" class="inner-hero__link">Activities</a>
            <a href="#food-drink" class="inner-hero__link">Food &amp; Drink</a>
          </nav>
        </div>
        <div class="inner-hero__image">
          <figure class="inner-hero__figure">
            <img src="/images/presteigne.jpg" alt="The Welsh Marches countryside near Presteigne" class="inner-hero__image-placeholder" loading="eager" decoding="async" />
            <figcaption class="section-img__caption">Presteigne High Street</figcaption>
          </figure>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       THE AREA
       ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="content-section" id="the-area" aria-labelledby="the-area-heading">
    <Container>
      <h2 class="content-section__heading" id="the-area-heading">{page?.theAreaHeading ?? "The Area"}</h2>

      <!-- Local Attractions -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.localAttractionsHeading ?? "Local Attractions"}</h3>
        <div class="subsection__body">
          <ul class="attraction-list">
            {(page?.localAttractions ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <figure class="section-img" data-reveal="fade">
        <img src="/images/local-area/garden.jpg" alt="Hergest Croft Gardens" loading="lazy" decoding="async" />
        <figcaption class="section-img__caption">Hergest Croft Gardens</figcaption>
      </figure>

      <!-- Slightly Further Afield -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.furtherAfieldHeading ?? "Slightly Further Afield"}</h3>
        <div class="subsection__body">
          <ul class="attraction-list">
            {(page?.furtherAfield ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      <figure class="section-img" data-reveal="fade">
        <img src="/images/local-area/elan.jpeg" alt="Elan Valley Reservoir" loading="lazy" decoding="async" />
        <figcaption class="section-img__caption">Elan Valley Reservoir</figcaption>
      </figure>

      <!-- Local Wildlife -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.localWildlifeHeading ?? "Local Wildlife"}</h3>
        <div class="subsection__prose">
          {(page?.localWildlifeParagraphs ?? []).map((p) => <p>{p}</p>)}
        </div>
      </div>

      <!-- What's On -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.whatsOnHeading ?? "What's On"}</h3>
        <div class="subsection__body">
          <ul class="attraction-list">
            {(page?.whatsOnItems ?? []).map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
      <figure class="section-img" data-reveal="fade">
        <img src="/images/local-area/car.jpg" alt="Presteigne Hill Climb" loading="lazy" decoding="async" />
        <figcaption class="section-img__caption">Presteigne Hill Climb</figcaption>
      </figure>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       ACTIVITIES
       ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="content-section content-section--alt" id="activities" aria-labelledby="activities-heading">
    <Container>
      <h2 class="content-section__heading" id="activities-heading">{page?.activitiesHeading ?? "Activities"}</h2>

      <!-- Walking (featured) -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.walkingHeading ?? "Walking"}</h3>
        <div class="subsection__prose">
          {(page?.walkingParagraphs ?? []).map((p) => <p>{p}</p>)}
        </div>
      </div>

      <figure class="section-img" data-reveal="fade">
        <img src="/images/local-area/hergest.webp" alt="The view from Hergest Ridge" loading="lazy" decoding="async" />
        <figcaption class="section-img__caption">The view from Hergest Ridge</figcaption>
      </figure>

      <!-- Activity cards -->
      <div class="activity-grid" data-reveal-stagger>
        {(page?.activityCards ?? []).map((card) => (
          <div class="activity-card">
            <h3 class="activity-card__title">{card.title}</h3>
            <p class="activity-card__desc">{card.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════════
       FOOD & DRINK
       ═══════════════════════════════════════════════════════════════════════════ -->
  <section class="content-section" id="food-drink" aria-labelledby="food-drink-heading">
    <Container>
      <h2 class="content-section__heading" id="food-drink-heading">{page?.foodDrinkHeading ?? "Food & Drink"}</h2>

      <!-- Overview -->
      <div class="subsection" data-reveal="slide-up">
        <div class="subsection__prose">
          <p>{page?.foodDrinkIntro}</p>
        </div>
      </div>

      <!-- Takeaway -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.takeawayHeading ?? "Takeaway"}</h3>
        <div class="subsection__prose">
          <p>{page?.takeawayDescription}</p>
        </div>
      </div>

      <!-- Eating out in Town -->
      <div class="portrait-section portrait-section--reverse" data-reveal="fade">
        <div class="subsection subsection--no-margin">
          <h3 class="subsection__heading">{page?.eatingOutHeading ?? "Eating Out in Town"}</h3>
          <div class="venue-grid" data-reveal-stagger>
            {(page?.townVenues ?? []).map((v) => (
              <div class="venue-card">
                <h4 class="venue-card__name">{v.name}</h4>
                <p class="venue-card__desc">{v.description}</p>
              </div>
            ))}
          </div>
        </div>
        <figure class="portrait-section__img">
          <img src="/images/local-area/daphnes.jpg" alt="Daphnes Pizza, Presteigne" loading="lazy" decoding="async" />
          <figcaption class="section-img__caption">Daphnes Pizza</figcaption>
        </figure>
      </div>

      <!-- Coffee & Tea -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.coffeeTeaHeading ?? "Coffee & Tea"}</h3>
        <div class="subsection__prose">
          <p>{page?.coffeeTeaDescription}</p>
        </div>
      </div>

      <!-- Just a Drink -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.justADrinkHeading ?? "Just a Drink"}</h3>
        <div class="subsection__prose">
          <p>{page?.justADrinkDescription}</p>
        </div>
      </div>

      <!-- Eating out further afield -->
      <div class="subsection" data-reveal="slide-up">
        <h3 class="subsection__heading">{page?.eatingOutFurtherHeading ?? "Eating Out Further Afield"}</h3>
        <div class="venue-grid" data-reveal-stagger>
          {(page?.furtherVenues ?? []).map((v) => (
            <div class="venue-card">
              <h4 class="venue-card__name">{v.name}</h4>
              {v.distance && <span class="venue-card__distance">{v.distance}</span>}
              <p class="venue-card__desc">{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <Container>
      <div class="cta-banner__inner" data-reveal="slide-up">
        <h2 class="cta-banner__title">{page?.ctaHeading ?? "Ready to explore?"}</h2>
        <p class="cta-banner__desc">{page?.ctaDescription ?? "Book your stay at Millie The Hut and discover the Welsh Marches for yourself."}</p>
        <a href="/book/" class="cta-banner__btn">Book Your Stay &rarr;</a>
      </div>
    </Container>
  </section>
</PageLayout>

<style>
  /* ─── Inner Hero ─── */
  .inner-hero {
    padding: var(--space-5xl) 0 var(--section-padding);
    background: var(--color-bg-white);
  }

  .inner-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .inner-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 70px);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    margin-bottom: var(--space-lg);
  }

  .inner-hero__subtitle {
    font-family: var(--font-sans);
    font-size: clamp(18px, 2.5vw, 25px);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 40ch;
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-xl);
  }

  .inner-hero__jump {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .inner-hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .inner-hero__link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-lg);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--duration-fast) var(--ease-out),
                color var(--duration-fast) var(--ease-out);
    letter-spacing: var(--tracking-tight);
  }

  .inner-hero__link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .inner-hero__figure {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .inner-hero__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-xl);
    object-fit: cover;
    display: block;
  }

  @media (min-width: 48rem) {
    .inner-hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }

  /* ─── Content Sections ─── */
  .content-section {
    padding: var(--section-padding) 0;
  }

  .content-section--alt {
    background: var(--color-surface);
  }

  .content-section__heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 50px);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
  }

  /* ─── Subsections ─── */
  .subsection {
    margin-bottom: var(--space-3xl);
  }

  .subsection:last-child {
    margin-bottom: 0;
  }

  .subsection__heading {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-lg);
    color: var(--color-text);
  }

  .subsection__prose p {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    max-width: 65ch;
  }

  .subsection__prose p:last-child {
    margin-bottom: 0;
  }

  /* ─── Attraction Lists ─── */
  .attraction-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .attraction-list li {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    padding-left: var(--space-lg);
    position: relative;
    max-width: 65ch;
  }

  .attraction-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: var(--radius-full);
  }

  /* ─── Section Images (landscape, full-width) ─── */
  .section-img {
    position: relative;
    margin: var(--space-3xl) 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .section-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  .section-img__caption {
    position: absolute;
    bottom: var(--space-md);
    right: var(--space-md);
    background: rgba(0, 0, 0, 0.52);
    color: #fff;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-md);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    pointer-events: none;
  }

  /* ─── Portrait Side Layouts ─── */
  .portrait-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: start;
    margin-bottom: var(--space-3xl);
  }

  .portrait-section__img {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    flex-shrink: 0;
  }

  .portrait-section__img img {
    width: 100%;
    height: auto;
    display: block;
  }

  .subsection--no-margin {
    margin-bottom: 0;
  }

  @media (min-width: 48rem) {
    .portrait-section {
      grid-template-columns: 1fr 260px;
      align-items: start;
    }

    .portrait-section--reverse {
      grid-template-columns: 1fr 220px;
    }
  }

  @media (min-width: 64rem) {
    .portrait-section {
      grid-template-columns: 1fr 300px;
    }

    .portrait-section--reverse {
      grid-template-columns: 1fr 260px;
    }
  }

  /* ─── Activity Cards ─── */
  .activity-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .activity-card {
    padding: var(--space-xl);
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .content-section--alt .activity-card {
    background: var(--color-bg-white);
  }

  .activity-card:hover {
    border-color: var(--color-primary);
  }

  .activity-card__title {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-sm);
  }

  .activity-card__desc {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.3vw, 16px);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  /* ─── Venue Cards ─── */
  .venue-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .venue-card {
    padding: var(--space-xl);
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .venue-card:hover {
    border-color: var(--color-primary);
  }

  .venue-card__name {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 22px);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-xs);
  }

  .venue-card__distance {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-sm);
  }

  .venue-card__desc {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.3vw, 16px);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  @media (min-width: 48rem) {
    .activity-grid,
    .venue-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .activity-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ─── CTA Banner ─── */
  .cta-banner {
    background: var(--color-text);
    color: var(--color-text-inverse);
    padding: var(--section-padding) 0;
  }

  .cta-banner__inner {
    text-align: center;
  }

  .cta-banner__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 50px);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-tight);
  }

  .cta-banner__desc {
    font-size: var(--text-lg);
    opacity: 0.8;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
    font-family: var(--font-serif);
    font-style: italic;
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: var(--space-md) var(--space-2xl);
    background: var(--color-cta);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: var(--weight-bold);
    border-radius: var(--radius-full);
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    letter-spacing: var(--tracking-tight);
  }

  .cta-banner__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
</style>
