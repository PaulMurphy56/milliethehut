---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const pageCollection = await getCollection("pageYourHosts");
const page = pageCollection[0]?.data;
---

<PageLayout
  title={page?.metaTitle ?? "Your Hosts | Millie The Hut"}
  description={page?.metaDescription}
>
  <!-- Inner Hero -->
  <section class="inner-hero">
    <Container>
      <div class="inner-hero__grid">
        <div class="inner-hero__text">
          <h1 class="inner-hero__title">{page?.pageTitle ?? "Meet Your Hosts"}</h1>
          <div class="inner-hero__bio" data-reveal="slide-up">
            {(page?.bioParagraphs ?? []).map((p) => <p>{p}</p>)}
          </div>
        </div>
        <div class="inner-hero__image">
          <figure class="inner-hero__figure">
            <img src="/images/hosts.JPG" alt="Paul and Glenys, your hosts at Millie The Hut" class="inner-hero__img" loading="eager" decoding="async" />
            <figcaption class="inner-hero__caption">You can be assured of a warm welcome at Millie, whatever the weather</figcaption>
          </figure>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <Container>
      <div class="cta-banner__inner" data-reveal="slide-up">
        <h2 class="cta-banner__title">{page?.ctaHeading ?? "Find out why our guests love Millie"}</h2>
        <a href="/book/" class="cta-banner__btn">Book Your Stay &rarr;</a>
      </div>
    </Container>
  </section>
</PageLayout>

<style>
  /* ─── Inner Hero ─── */
  .inner-hero {
    padding: var(--space-5xl) 0 var(--section-padding);
    background: var(--color-bg-white);
  }

  .inner-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .inner-hero__eyebrow {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: var(--weight-bold);
    letter-spacing: 0.15em;
    color: var(--color-primary);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .inner-hero__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 70px);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    line-height: 1.1;
    margin-bottom: var(--space-xl);
  }

  .inner-hero__bio p {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    max-width: 60ch;
  }

  .inner-hero__bio p:last-child {
    margin-bottom: 0;
  }

  .inner-hero__figure {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .inner-hero__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-xl);
  }

  .inner-hero__caption {
    display: block;
    margin-top: var(--space-sm);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (min-width: 48rem) {
    .inner-hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }
  }

  /* ─── CTA Banner ─── */
  .cta-banner {
    background: var(--color-text);
    color: var(--color-text-inverse);
    padding: var(--section-padding) 0;
  }

  .cta-banner__inner {
    text-align: center;
  }

  .cta-banner__title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-2xl);
    letter-spacing: var(--tracking-tight);
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: var(--space-md) var(--space-2xl);
    background: var(--color-cta);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: var(--weight-bold);
    border-radius: var(--radius-full);
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out);
    letter-spacing: var(--tracking-tight);
  }

  .cta-banner__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }
</style>
