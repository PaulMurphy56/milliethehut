---
import PageLayout from "../layouts/PageLayout.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const allTestimonials = await getCollection("testimonials");
const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);

const siteSettingsCollection = await getCollection("siteSettings");
const site = siteSettingsCollection[0]?.data;
---

<PageLayout
  title="Millie The Hut | Shepherd's Hut Glamping in the Welsh Marches, Herefordshire"
  description="Escape to Millie The Hut — a beautifully appointed shepherd's hut nestled in the Welsh Marches near Presteigne. Luxury glamping for two with a wood burner, fire pit & stunning countryside views."
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="hero__frame">
      <img
        src="/images/hero.avif"
        alt="Millie The Hut shepherd's hut at golden hour in the Welsh Marches countryside"
        class="hero__img"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero__overlay">
        <h1 class="hero__title">Millie<br />The Hut</h1>
        <p class="hero__tagline">Escape to the Welsh Marches</p>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section" aria-labelledby="intro-heading">
    <Container narrow>
      <div class="intro">
        <h2 class="intro__heading" id="intro-heading">Millie The Hut, Presteigne, Herefordshire.</h2>
        <div class="intro__text" id="scroll-text">
          <p>Down a leafy lane, where steam trains once ran, across a Victorian railway bridge that takes you from Wales to England, you'll find a meadow where sheep graze, and a traditional-style Shepherds Hut and Shack. On sunny days, the meadow is bathed in light from dawn to dusk, and the gin-clear Hindwell Brook that bounds it flashes silver. Whatever the weather, after dark is a special time to be here, when the log burner in the hut, the firepit by the stream and the lamps and candles in the Shack cast a magical golden glow.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Trust Indicators -->
  <section class="section" aria-labelledby="trust-heading">
    <Container>
      <h2 class="sr-only" id="trust-heading">Why Choose Millie The Hut</h2>
      <div class="trust" data-reveal-stagger>
        <div class="trust__item">
          <svg class="trust__icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256" fill="currentColor"><path d="M234.5,114.38l-45.1,39.36,13.51,58.6a16,16,0,0,1-23.84,17.34l-51.11-31-51,31a16,16,0,0,1-23.84-17.34L66.61,153.8,21.5,114.38a16,16,0,0,1,9.11-28.06l59.46-5.15,23.21-55.36a15.95,15.95,0,0,1,29.44,0h0L166,81.17l59.44,5.15a16,16,0,0,1,9.11,28.06Z"/></svg>
          <p class="trust__label">Exceptional Guest Reviews</p>
        </div>
        <div class="trust__item">
          <svg class="trust__icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256" fill="currentColor"><path d="M232,96a72.08,72.08,0,0,0-72-72H96A72.08,72.08,0,0,0,24,96c0,28.81,9.88,51.14,30.42,69.48A156.28,156.28,0,0,1,88,207.45V224a16,16,0,0,0,16,16h48a16,16,0,0,0,16-16V207.45a156.28,156.28,0,0,1,33.58-41.97C222.12,147.14,232,124.81,232,96ZM185.5,150.48A171.53,171.53,0,0,0,149.09,196H136V148.94l26.35-21.09a8,8,0,1,0-10-12.48L128,134.42l-24.36-19.05a8,8,0,1,0-10,12.48L120,148.94V196H106.91a171.53,171.53,0,0,0-36.41-45.52C52.25,134.28,40,115.54,40,96A56.06,56.06,0,0,1,96,40h64a56.06,56.06,0,0,1,56,56C216,115.54,203.75,134.28,185.5,150.48Z"/></svg>
          <p class="trust__label">Peaceful Countryside Escape</p>
        </div>
        <div class="trust__item">
          <svg class="trust__icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 256 256" fill="currentColor"><path d="M152,40V16a8,8,0,0,0-16,0V40a8,8,0,0,0,16,0Zm68.49,59.12a8,8,0,0,0,5.65-2.34l16.97-17a8,8,0,0,0-11.32-11.32l-16.97,17a8,8,0,0,0,5.67,13.66ZM232,120H208a8,8,0,0,0,0,16h24a8,8,0,0,0,0-16ZM79.51,99.12a8,8,0,0,0,11.32-11.32l-17-17A8,8,0,0,0,62.54,82.1ZM80,128a8,8,0,0,0-8-8H48a8,8,0,0,0,0,16H72A8,8,0,0,0,80,128Zm64,72a8,8,0,0,0-8,8v24a8,8,0,0,0,16,0V208A8,8,0,0,0,144,200Zm64.48-37.88-17,17a8,8,0,0,0,11.32,11.32l17-17a8,8,0,0,0-11.32-11.32Zm-145-17a8,8,0,0,0-11.32,0l-17,17a8,8,0,0,0,11.32,11.32l17-17A8,8,0,0,0,63.51,145.12ZM144,72a56,56,0,1,0,56,56A56.06,56.06,0,0,0,144,72Z"/></svg>
          <p class="trust__label">Cosy Year-Round Retreat</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Gallery Preview -->
  <section class="section" aria-labelledby="gallery-heading">
    <Container>
      <h2 class="section__heading" id="gallery-heading">Gallery</h2>
      <div class="gallery-preview" data-reveal="fade">
        <div class="gallery-preview__left">
          <div class="gallery-preview__img-wrap gallery-preview__img-wrap--portrait">
            <img src="https://placehold.co/600x900/e8ddd3/666?text=Portrait+Image" alt="Gallery preview — portrait image of the shepherd's hut" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="gallery-preview__right">
          <div class="gallery-preview__img-wrap">
            <img src="https://placehold.co/700x450/e8ddd3/666?text=Landscape+Image+1" alt="Gallery preview — landscape image of the meadow" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-preview__img-wrap">
            <img src="https://placehold.co/700x450/e8ddd3/666?text=Landscape+Image+2" alt="Gallery preview — landscape image of the interior" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
      <div class="gallery-preview__cta">
        <a href="/gallery/" class="btn">View All &rarr;</a>
      </div>
    </Container>
  </section>

  <!-- Facilities -->
  <section class="section" aria-labelledby="facilities-heading">
    <Container>
      <h2 class="section__heading" id="facilities-heading">Our Facilities</h2>
      <ul class="facilities" data-reveal-stagger>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M64,236a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H56A8,8,0,0,1,64,236Zm152-8H200a8,8,0,0,0,0,16h16a8,8,0,0,0,0-16Zm24-100v40a8,8,0,0,1-16,0V176H32v-8a8,8,0,0,1-16,0v-40a8,8,0,0,1,16,0v8H88V112a32,32,0,0,1,32-32h16a32,32,0,0,1,32,32v24h56v-8a8,8,0,0,1,16,0ZM152,136V112a16,16,0,0,0-16-16H120a16,16,0,0,0-16,16v24Z"/></svg>
          <span>En suite shower &amp; flushing toilet</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M200,32H56A24,24,0,0,0,32,56V200a24,24,0,0,0,24,24H200a24,24,0,0,0,24-24V56A24,24,0,0,0,200,32Zm8,168a8,8,0,0,1-8,8H56a8,8,0,0,1-8-8V56a8,8,0,0,1,8-8H200a8,8,0,0,1,8,8Zm-40-88a36,36,0,1,1-36-36A36,36,0,0,1,168,112Z"/></svg>
          <span>Bedding, towels &amp; toiletries</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M224,104h-8.4a79.76,79.76,0,0,0-25.29-42.63l15.41-15.41a8,8,0,1,0-11.32-11.32L178.9,50.14A79.53,79.53,0,0,0,144,40.36V24a8,8,0,0,0-16,0V40.36A79.53,79.53,0,0,0,93.1,50.14L77.6,34.64a8,8,0,1,0-11.32,11.32l15.41,15.41A79.76,79.76,0,0,0,56.4,104H48a8,8,0,0,0,0,16h8v8a79.72,79.72,0,0,0,28.93,61.54l-16.65,16.65a8,8,0,0,0,11.32,11.32l18-18A79.4,79.4,0,0,0,128,208a79.4,79.4,0,0,0,30.4-18.49l18,18a8,8,0,0,0,11.32-11.32l-16.65-16.65A79.72,79.72,0,0,0,200,128v-8h8a8,8,0,0,0,0-16Z"/></svg>
          <span>Eggs, milk, tea, coffee, oils etc</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M88,48V16a8,8,0,0,1,16,0V48a8,8,0,0,1-16,0Zm40,8a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V48A8,8,0,0,0,128,56Zm32,0a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V48A8,8,0,0,0,160,56Zm72,64v16a8,8,0,0,1-16,0V128a8,8,0,0,0-8-8H48a8,8,0,0,0-8,8v56a32,32,0,0,0,32,32H184a32,32,0,0,0,32-32,8,8,0,0,1,16,0,48.05,48.05,0,0,1-48,48H72a48.05,48.05,0,0,1-48-48V128a24,24,0,0,1,24-24h8V88a8,8,0,0,1,16,0v16H184V88a8,8,0,0,1,16,0v16h8a24,24,0,0,1,24,24Z"/></svg>
          <span>Induction hob, microwave, toaster, kettle</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M208,40H48A16,16,0,0,0,32,56V200a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM48,56H208V96H48ZM48,200V112H208v88Z"/></svg>
          <span>Fridge with ice box</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm45.66-93.66a8,8,0,0,1,0,11.32l-32,32a8,8,0,0,1-11.32-11.32L148.69,136H88a8,8,0,0,1,0-16h60.69l-18.35-18.34a8,8,0,0,1,11.32-11.32Z"/></svg>
          <span>USB points</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M168,128a40,40,0,1,1-40-40A40,40,0,0,1,168,128Zm-24-96H112a8,8,0,0,0,0,16h32a8,8,0,0,0,0-16Zm80,64V232a24,24,0,0,1-24,24H56a24,24,0,0,1-24-24V96A24,24,0,0,1,56,72H200A24,24,0,0,1,224,96Z"/></svg>
          <span>Wood burner</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24C74.17,24,28,63.07,28,112c0,28.28,15.07,54.11,40,72V224a8,8,0,0,0,12.8,6.4L128,196l47.2,34.4A8,8,0,0,0,188,224V184c24.93-17.89,40-43.72,40-72C228,63.07,181.83,24,128,24Z"/></svg>
          <span>Kadai fire pit &amp; barbecue</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216ZM172.42,72.84l-64,32a8.05,8.05,0,0,0-3.58,3.58l-32,64A8,8,0,0,0,80,184a8.1,8.1,0,0,0,3.58-.84l64-32a8.05,8.05,0,0,0,3.58-3.58l32-64a8,8,0,0,0-10.74-10.74ZM138,138,97.89,158.11,118,118l40.15-20.07Z"/></svg>
          <span>Bluetooth radio &amp; board games</span>
        </li>
      </ul>
    </Container>
  </section>

  <!-- The Important Bits -->
  <section class="section" aria-labelledby="important-heading">
    <Container>
      <h2 class="section__heading" id="important-heading">The Important Bits</h2>
      <div class="important" data-reveal-stagger>
        <div class="important__item">
          <svg class="important__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M117.25,157.92a60,60,0,1,0-66.5,0A95.83,95.83,0,0,0,3.24,195.63a8,8,0,1,0,13.52,8.74,80,80,0,0,1,134.48,0,8,8,0,0,0,13.52-8.74A95.83,95.83,0,0,0,117.25,157.92ZM40,108a44,44,0,1,1,44,44A44.05,44.05,0,0,1,40,108Zm210.76,87.63a95.83,95.83,0,0,0-47.51-37.71A60,60,0,0,0,168,40a59.75,59.75,0,0,0-40,15.26,8,8,0,1,0,10.67,11.92A44,44,0,1,1,168,152a8,8,0,0,0-6.76,12.28,96,96,0,0,1,9.53,16.09,8,8,0,0,0,4.39,4.24A79.36,79.36,0,0,1,212.76,204a8,8,0,1,0,13.52-8.74,95.52,95.52,0,0,0-25.52-19.63,43.83,43.83,0,0,0,18-9.71Z"/></svg>
          <p class="important__label">Sleeps Two</p>
          <p class="important__sub">No babies or children</p>
        </div>
        <div class="important__item">
          <svg class="important__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm64-88a8,8,0,0,1-8,8H128a8,8,0,0,1-8-8V72a8,8,0,0,1,16,0v48h48A8,8,0,0,1,192,128Z"/></svg>
          <p class="important__label">Check-in 3pm / Check-out 10am</p>
        </div>
        <div class="important__item">
          <svg class="important__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M208,136H176a8,8,0,0,1-6.76-3.71L152,104.85,119.24,164.29a8,8,0,0,1-14.48,0L80,118.85l-9.24,13.43A8,8,0,0,1,64,136H24a8,8,0,0,1,0-16H58.75l15.49-22.57a8,8,0,0,1,13.53,0L112,143.15l32.76-59.44a8,8,0,0,1,14.48,0L181.25,120H208a8,8,0,0,1,0,16ZM128,216a88.11,88.11,0,0,1-79-49.07,8,8,0,0,1,14.36-7.07,72,72,0,0,0,129.36,0,8,8,0,0,1,14.36,7.07A88.11,88.11,0,0,1,128,216Z"/></svg>
          <p class="important__label">No Pets</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Testimonials -->
  <section class="section" aria-labelledby="testimonials-heading">
    <Container narrow>
      <h2 class="section__heading" id="testimonials-heading">Words From Our Guests</h2>
      <div class="testimonials" id="testimonial-slider">
        <div class="testimonials__track">
          {allTestimonials.length > 0 ? (
            allTestimonials.map((t, i) => (
              <blockquote class={`testimonials__slide ${i === 0 ? 'is-active' : ''}`} data-slide={i}>
                <span class="testimonials__quote" aria-hidden="true">&ldquo;</span>
                <div class="testimonials__body">
                  <p class="testimonials__text" data-full-text={t.body}>{t.body}</p>
                </div>
                <footer class="testimonials__author">
                  <span class="testimonials__name">{t.data.name}</span>
                  <span class="testimonials__location">{t.data.location}</span>
                </footer>
              </blockquote>
            ))
          ) : (
            <>
              <blockquote class="testimonials__slide is-active" data-slide="0">
                <span class="testimonials__quote" aria-hidden="true">&ldquo;</span>
                <div class="testimonials__body">
                  <p class="testimonials__text">The most magical place we've ever stayed. Waking up to the sound of the brook and the sheep grazing in the meadow was absolutely heavenly. The hut has everything you need and more. We didn't want to leave and are already planning our return trip.</p>
                </div>
                <footer class="testimonials__author">
                  <span class="testimonials__name">Sarah &amp; James</span>
                  <span class="testimonials__location">Bristol</span>
                </footer>
              </blockquote>
              <blockquote class="testimonials__slide" data-slide="1">
                <span class="testimonials__quote" aria-hidden="true">&ldquo;</span>
                <div class="testimonials__body">
                  <p class="testimonials__text">A truly special retreat. The attention to detail is extraordinary — from the wood burner to the fire pit by the stream, every moment felt considered. The perfect escape from city life. Cannot recommend highly enough.</p>
                </div>
                <footer class="testimonials__author">
                  <span class="testimonials__name">Emily</span>
                  <span class="testimonials__location">London</span>
                </footer>
              </blockquote>
              <blockquote class="testimonials__slide" data-slide="2">
                <span class="testimonials__quote" aria-hidden="true">&ldquo;</span>
                <div class="testimonials__body">
                  <p class="testimonials__text">We celebrated our anniversary here and it was perfection. Sitting by the fire pit under a sky full of stars with the sound of the brook — pure magic. The hosts thought of everything. A real hidden gem on the Welsh border.</p>
                </div>
                <footer class="testimonials__author">
                  <span class="testimonials__name">Tom &amp; Lucy</span>
                  <span class="testimonials__location">Birmingham</span>
                </footer>
              </blockquote>
            </>
          )}
        </div>
        <div class="testimonials__controls">
          <button class="testimonials__btn" type="button" aria-label="Previous testimonial" data-dir="prev">&larr;</button>
          <div class="testimonials__dots" role="tablist" aria-label="Testimonial navigation">
            {(allTestimonials.length > 0 ? allTestimonials : [0, 1, 2]).map((_, i) => (
              <button
                class={`testimonials__dot ${i === 0 ? 'is-active' : ''}`}
                type="button"
                role="tab"
                aria-selected={i === 0 ? "true" : "false"}
                aria-label={`Testimonial ${i + 1}`}
                data-dot={i}
              ></button>
            ))}
          </div>
          <button class="testimonials__btn" type="button" aria-label="Next testimonial" data-dir="next">&rarr;</button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Location & Map -->
  <section class="section" aria-labelledby="location-heading">
    <Container>
      <h2 class="section__heading" id="location-heading">Where to Find Us</h2>
      <div class="location">
        <div class="location__info">
          <div class="location__w3w">
            <h3 class="location__sub-heading">What3Words</h3>
            <p class="location__words">///unwanted.passports.among</p>
            <p class="location__w3w-explain">What3Words divides the world into 3m squares, each with a unique three-word address. Use it for accurate navigation directly to Millie The Hut.</p>
          </div>
          <address class="location__address">
            Wegnall's Mill<br />
            Presteigne<br />
            Powys<br />
            LD8 2LD
          </address>
        </div>
        <div class="location__map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2452.5!2d-3.0!3d52.27!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTLCsDE2JzEyLjAiTiAzwrAwMCcwMC4wIlc!5e0!3m2!1sen!2suk!4v1"
            width="100%"
            height="400"
            style="border:0; border-radius: var(--radius-xl);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map showing location of Millie The Hut near Presteigne, Powys"
          ></iframe>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
