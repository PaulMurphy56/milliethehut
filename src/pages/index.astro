---
import PageLayout from "../layouts/PageLayout.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const allTestimonials = await getCollection("testimonials");
const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);

const siteSettingsCollection = await getCollection("siteSettings");
const site = siteSettingsCollection[0]?.data;

const facilities = [
  { icon: "shower",  label: "En suite shower & flushing toilet" },
  { icon: "bed",     label: "Bedding, towels & toiletries" },
  { icon: "egg",     label: "Eggs, milk, tea, coffee, oils etc" },
  { icon: "cooking", label: "Induction hob, microwave, toaster, kettle" },
  { icon: "fridge",  label: "Fridge with ice box" },
  { icon: "usb",     label: "USB points" },
  { icon: "fire",    label: "Wood burner" },
  { icon: "firepit", label: "Kadai fire pit & barbecue" },
  { icon: "music",   label: "Bluetooth radio & board games" },
];

const importantBits = [
  { icon: "people", title: "Sleeps Two",                        note: "No babies or children" },
  { icon: "clock",  title: "Check-in 3pm / Check-out 10am",    note: "Flexible by arrangement" },
  { icon: "nopets", title: "No Pets",                           note: "Sorry, no exceptions" },
];

const reviews = allTestimonials.length > 0 ? allTestimonials : [
  { data: { name: "Sarah & James", location: "Hereford", rating: 5, body: "Millie The Hut is simply magical. We arrived to a perfectly set hut, lit the fire pit as the sun went down, and didn't want to leave. The most restorative weekend we've had in years. If you're looking for somewhere to truly switch off, this is it." }},
  { data: { name: "Tom & Emily",   location: "Birmingham", rating: 5, body: "The perfect escape. Waking up to birdsong and the most incredible views of the countryside. The hut has everything you need and more. We've already booked our next stay." }},
  { data: { name: "Rachel D.",     location: "London", rating: 5, body: "Absolutely wonderful. The attention to detail is second to none. From the welcome hamper to the cosy wood burner, every moment felt special. A true hidden gem in the Welsh Marches — we told everyone about it when we got home." }},
];

const faqs = sortedFaqs.length > 0 ? sortedFaqs : [
  { data: { question: "What is there to do near Millie The Hut shepherd's hut in Herefordshire?", answer: "You're perfectly placed for exploring the best of the Welsh Marches. Presteigne is a charming market town just minutes away, while Hay-on-Wye — famous for its bookshops — is a scenic 30-minute drive. Offa's Dyke National Trail passes close by for walkers, and the Brecon Beacons are within easy reach for a day out." }},
  { data: { question: "Is there Wi-Fi at the shepherd's hut?", answer: "Millie The Hut is intentionally off-grid in spirit — we find the best breaks involve disconnecting a little. That said, mobile signal is available and our Bluetooth radio will keep you entertained. We encourage you to swap the scroll for a stroll." }},
  { data: { question: "Is there parking at the glamping site?", answer: "Yes, there is private off-road parking directly at the hut for one vehicle. The location is easily accessible by car from the A44/A4113 corridor." }},
  { data: { question: "What should I pack for a stay at Millie The Hut?", answer: "We supply bedding, towels, toiletries, and a welcome hamper with essentials like eggs, milk, tea and coffee. We recommend packing weather-appropriate clothing (it's the Welsh Marches — be prepared for anything!), walking boots, and a good book. A torch can be handy for evening stargazing." }},
  { data: { question: "Can I have a fire at the glamping hut?", answer: "Absolutely — it's one of the highlights. The Kadai fire pit and barbecue are yours to enjoy, and the wood burner inside keeps the hut beautifully warm on cooler evenings. Logs and kindling are provided." }},
  { data: { question: "How do I find Millie The Hut? Is it easy to locate in the countryside?", answer: "We're located at Wegnall's Mill, Presteigne, Powys, LD8 2LD. The easiest way to find us is with What3Words: ///unwanted.passports.among — just enter this into the What3Words app and it will guide you right to the door. Full arrival instructions are sent with your booking confirmation." }},
];
---

<PageLayout
  title="Millie The Hut | Shepherd's Hut Glamping in the Welsh Marches, Herefordshire"
  description="Escape to Millie The Hut — a beautifully appointed shepherd's hut nestled in the Welsh Marches near Presteigne. Luxury glamping for two with a wood burner, fire pit & stunning countryside views."
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- ═══ SECTION 1: HERO ═══════════════════════ -->
  <section class="hero" aria-label="Welcome to Millie The Hut">
    <div class="hero__card">
      <img
        src="/images/hero.avif"
        alt="Millie The Hut shepherd's hut at golden hour in the Welsh Marches countryside"
        class="hero__img"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero__overlay"></div>

      <!-- Nav inside the image card -->
      <nav class="hero-nav" aria-label="Main navigation">
        <ul class="hero-nav__list" role="list">
          <li><a href="/gallery/" class="hero-nav__link">Gallery</a></li>
          <li><a href="/location/" class="hero-nav__link">Local Area</a></li>
          <li><a href="/your-hosts/" class="hero-nav__link">Your Hosts</a></li>
          <li><a href="/contact/" class="hero-nav__link">Contact</a></li>
        </ul>
        <a href={site?.bookingUrl ?? "/book/"} class="hero-nav__book">
          <span>Book Now</span>
          <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M200,64V168a8,8,0,0,1-16,0V83.31L69.66,197.66a8,8,0,0,1-11.32-11.32L172.69,72H88a8,8,0,0,1,0-16H192A8,8,0,0,1,200,64Z"/>
          </svg>
        </a>
      </nav>

      <!-- Mobile hamburger inside hero -->
      <button class="hero-menu-btn" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="hero-menu-icon"></span>
      </button>

      <!-- Brand overlay -->
      <h1 class="hero__brand">Millie<br/>The Hut</h1>

      <!-- Tagline bottom-right -->
      <p class="hero__tagline">Escape to the Welsh Marches.</p>
    </div>
  </section>

  <!-- ═══ SECTION 2: INTRODUCTION ═══════════════ -->
  <section class="intro section" aria-labelledby="intro-heading">
    <Container>
      <h2 class="intro__heading" id="intro-heading">
        Millie The Hut,<br/>Presteigne, Herefordshire.
      </h2>

      <div class="intro__text-wrap">
        <p class="intro__text" id="intro-animated-text">Down a leafy lane, where steam trains once ran, across a Victorian railway bridge that takes you from Wales to England, you'll find a meadow where sheep graze, and what else, but a traditional-style Shepherds Hut and Shack. On sunny days, the meadow is bathed in light from dawn to dusk, and the gin-clear Hindwell Brook that bounds it flashes silver. Whatever the weather, after dark is a special time to be here, when the log burner in the hut, the firepit by the stream and the lamps and candles in the Shack cast a magical golden glow.</p>
      </div>

      <!-- Separator + Trust Bar -->
      <hr class="intro__divider" />
      <div class="trust-bar" aria-label="Awards and features">
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="30" stroke="#e3977b" stroke-width="1.5"/>
              <path d="M32 16l4.6 9.6 10.6 1.5-7.6 7.4 1.8 10.5L32 40.2l-9.4 4.8 1.8-10.5-7.6-7.4 10.6-1.5L32 16z" fill="#e3977b"/>
            </svg>
          </div>
          <p class="trust-bar__label">Luxury Glamping<br/><span>Welsh Marches</span></p>
        </div>
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="13" width="44" height="38" rx="4" stroke="#e3977b" stroke-width="1.5"/>
              <path d="M22 32h20M22 40h14" stroke="#e3977b" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="32" cy="24" r="5" stroke="#e3977b" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="trust-bar__label">Guests Rate Us<br/><span>5 Stars</span></p>
        </div>
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M32 10C23.16 10 16 18.6 16 29c0 14.4 16 31 16 31s16-16.6 16-31c0-10.4-7.16-19-16-19z" stroke="#e3977b" stroke-width="1.5"/>
              <circle cx="32" cy="29" r="6" stroke="#e3977b" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="trust-bar__label">Near Presteigne<br/><span>Powys, Wales</span></p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═══ SECTION 3: GALLERY PREVIEW ═══════════ -->
  <section class="gallery-preview section" aria-label="Photo gallery">
    <Container>
      <div class="gallery-collage">
        <div class="gallery-collage__left">
          <div class="gallery-collage__img-wrap">
            <div class="gallery-collage__placeholder" aria-label="Interior of Millie The Hut"><span>Interior</span></div>
          </div>
        </div>
        <div class="gallery-collage__right">
          <div class="gallery-collage__img-wrap">
            <div class="gallery-collage__placeholder" aria-label="The private deck"><span>The Deck</span></div>
          </div>
          <div class="gallery-collage__img-wrap">
            <div class="gallery-collage__placeholder" aria-label="Evening fire pit"><span>Fire Pit</span></div>
          </div>
        </div>
      </div>
      <div class="gallery-preview__action">
        <a href="/gallery/" class="btn-outline-dark">
          View All Photos
          <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/></svg>
        </a>
      </div>
    </Container>
  </section>

  <!-- ═══ SECTION 4: FACILITIES ══════════════════ -->
  <section class="facilities section section--surface" aria-labelledby="facilities-heading">
    <Container>
      <h2 class="section-heading" id="facilities-heading">Our Facilities</h2>
      <div class="facilities-grid">
        {facilities.map((item) => (
          <div class="facility-card">
            <div class="facility-card__icon" aria-hidden="true">
              {item.icon === "shower" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M208,136H111.51l99.82-99.82a8,8,0,0,0-11.32-11.32L99.52,125.45a95.91,95.91,0,0,0-53.2-29.14,8,8,0,0,0-2.64,15.78A80,80,0,0,1,128,192v8a8,8,0,0,0,16,0v-8h64a8,8,0,0,0,0-16ZM80,200a8,8,0,1,1-8-8A8,8,0,0,1,80,200Zm-32,0a8,8,0,1,1-8-8A8,8,0,0,1,48,200Zm16-28a8,8,0,1,1-8-8A8,8,0,0,1,64,172Z"/></svg>
              )}
              {item.icon === "bed" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M208,72H24V48a8,8,0,0,0-16,0V208a8,8,0,0,0,16,0v-40H232v40a8,8,0,0,0,16,0V112A40,40,0,0,0,208,72ZM24,88h84v64H24Zm100,64V88h84a24,24,0,0,1,24,24v40Z"/></svg>
              )}
              {item.icon === "egg" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M186.67,123.87C179.73,82.79,158.43,40,128,40S76.27,82.79,69.33,123.87C63.44,158.49,69.21,192,89.09,211a52,52,0,0,0,77.82,0C186.79,192,192.56,158.49,186.67,123.87Z"/></svg>
              )}
              {item.icon === "cooking" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M88,48V16a8,8,0,0,1,16,0V48a8,8,0,0,1-16,0Zm40,8a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V48A8,8,0,0,0,128,56Zm32,0a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V48A8,8,0,0,0,160,56Zm72,48v8a8,8,0,0,1-8,8H224v64a24,24,0,0,1-24,24H56a24,24,0,0,1-24-24V120H24a8,8,0,0,1,0-16h8V96a8,8,0,0,1,8-8H216a8,8,0,0,1,8,8v8h8A8,8,0,0,1,232,104Z"/></svg>
              )}
              {item.icon === "fridge" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M176,16H80A24,24,0,0,0,56,40V216a24,24,0,0,0,24,24h96a24,24,0,0,0,24-24V40A24,24,0,0,0,176,16Zm8,200a8,8,0,0,1-8,8H80a8,8,0,0,1-8-8V136H184Zm0-96H72V40a8,8,0,0,1,8-8h96a8,8,0,0,1,8,8ZM120,76V60a8,8,0,0,1,16,0V76a8,8,0,0,1-16,0Zm0,104v-16a8,8,0,0,1,16,0v16a8,8,0,0,1-16,0Z"/></svg>
              )}
              {item.icon === "usb" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M208,56a16,16,0,1,0-16-16A16,16,0,0,0,208,56Zm-72,48a16,16,0,1,0-16-16A16,16,0,0,0,136,104Zm88,40H136V120.27A32,32,0,0,0,160,88V56A32,32,0,0,0,96,56V88a32,32,0,0,0,24,31.12V144H32a8,8,0,0,0,0,16h88v24.88A32,32,0,0,0,96,216v32a32,32,0,0,0,64,0V216a32,32,0,0,0-24-30.91V160h88a8,8,0,0,0,0-16Z"/></svg>
              )}
              {item.icon === "fire" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M173.88,103.27C169,90.66,158.26,79.42,141.57,68.43a8,8,0,0,0-11.06,2.31,76.61,76.61,0,0,1-10.68,13.15c-5.15,5.16-8.43,4-9.09,3.66-3.89-2.15-6.72-11.16-4.8-28.11a8,8,0,0,0-12.59-7.43C80.47,62.78,40,98.06,40,152a88,88,0,0,0,176,0C216,133.79,197.27,112.16,173.88,103.27Z"/></svg>
              )}
              {item.icon === "firepit" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M128,16C73.86,16,28,50.59,28,96c0,22.58,12.13,43.17,34.15,58A8,8,0,0,0,72,152h0a8,8,0,0,0-1.65-11.31C52.64,127.76,44,112.31,44,96c0-37.5,37.71-64,84-64s84,26.5,84,64c0,16.31-8.64,31.76-26.35,44.69A8,8,0,0,0,184,152a8,8,0,0,0,9.85-1.95C215.87,139.17,228,118.58,228,96,228,50.59,182.14,16,128,16ZM72,176v48a8,8,0,0,0,16,0V176a8,8,0,0,0-16,0Zm40,0v48a8,8,0,0,0,16,0V176a8,8,0,0,0-16,0Zm40,0v48a8,8,0,0,0,16,0V176a8,8,0,0,0-16,0Z"/></svg>
              )}
              {item.icon === "music" && (
                <svg width="44" height="44" viewBox="0 0 256 256" fill="currentColor"><path d="M212.92,25.55a8,8,0,0,0-6.86-1.45l-128,32A8,8,0,0,0,72,64V176a36,36,0,1,0,16,30V120.43l112-28V136a36,36,0,1,0,16,30V32A8,8,0,0,0,212.92,25.55ZM52,228a20,20,0,1,1,20-20A20,20,0,0,1,52,228Zm128-32a20,20,0,1,1,20-20A20,20,0,0,1,180,196ZM88,103.57V69.83l112-28v33.74Z"/></svg>
              )}
            </div>
            <p class="facility-card__label">{item.label}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══ SECTION 5: THE IMPORTANT BITS ══════════ -->
  <section class="important section" aria-labelledby="important-heading">
    <Container>
      <h2 class="section-heading" id="important-heading">The Important Bits</h2>
      <div class="important-grid">
        {importantBits.map((bit) => (
          <div class="important-item">
            <div class="important-item__icon" aria-hidden="true">
              {bit.icon === "people" && (
                <svg width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M244.8,150.4a8,8,0,0,1-11.2-1.6A51.6,51.6,0,0,0,192,128a8,8,0,0,1-7.37-4.89,8,8,0,0,1,1.1-8.33A24,24,0,1,0,150.92,88h0a8,8,0,0,1-16,0h0a40,40,0,1,1,68.19,28.09A67.72,67.72,0,0,1,220,128,51.6,51.6,0,0,1,246.4,161.6,8,8,0,0,1,244.8,150.4ZM190,212a8,8,0,0,1-8,8H74a8,8,0,0,1-8-8,64,64,0,0,1,128,0Zm-16.33,0a48,48,0,0,0-91.34,0ZM128,152a40,40,0,1,0-40-40A40,40,0,0,0,128,152Zm0-64a24,24,0,1,1-24,24A24,24,0,0,1,128,88ZM72,128a8,8,0,0,0-8-8A51.6,51.6,0,0,0,22.4,148.8a8,8,0,1,0,12.8,9.6A35.72,35.72,0,0,1,64,144,8,8,0,0,0,72,128Z"/></svg>
              )}
              {bit.icon === "clock" && (
                <svg width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm64-88a8,8,0,0,1-8,8H128a8,8,0,0,1-8-8V72a8,8,0,0,1,16,0v48h48A8,8,0,0,1,192,128Z"/></svg>
              )}
              {bit.icon === "nopets" && (
                <svg width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M213.92,210.62l-160-176A8,8,0,1,0,42.08,45.38L68.9,75.09A64,64,0,0,0,53.5,168.67l-9.41,18.82A8,8,0,0,0,51.29,199a7.6,7.6,0,0,0,3.6.86,8,8,0,0,0,7.18-4.43l8-16a63.49,63.49,0,0,0,58,0l8,16A8,8,0,0,0,143.11,200a7.6,7.6,0,0,0,3.6-.86,8,8,0,0,0,3.58-10.74l-9.18-18.35a64.15,64.15,0,0,0,17.48-13.15l44.49,49A8,8,0,0,0,208,208a8,8,0,0,0,5.92-13.38Z"/></svg>
              )}
            </div>
            <h3 class="important-item__title">{bit.title}</h3>
            <p class="important-item__note">{bit.note}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══ SECTION 6: TESTIMONIALS SLIDER ═════════ -->
  <section class="testimonials section section--surface" aria-labelledby="reviews-heading">
    <Container>
      <h2 class="section-heading" id="reviews-heading">Words From Our Guests</h2>
      <div class="testimonial-slider" role="region" aria-label="Guest testimonials">
        <div class="testimonial-slider__track" id="testimonial-track">
          {reviews.map((t, i) => (
            <article class="testimonial-slide" id={`slide-${i}`} aria-hidden={i > 0 ? "true" : "false"}>
              <div class="testimonial-slide__quote-mark" aria-hidden="true">&ldquo;</div>
              <div class="testimonial-slide__stars" aria-label={`${t.data.rating} out of 5 stars`}>
                {"★".repeat(t.data.rating)}{"☆".repeat(5 - t.data.rating)}
              </div>
              <blockquote class="testimonial-slide__quote">
                <p class="testimonial-slide__text">{t.data.body}</p>
              </blockquote>
              <footer class="testimonial-slide__footer">
                <strong class="testimonial-slide__name">{t.data.name}</strong>
                {t.data.location && <span class="testimonial-slide__location">{t.data.location}</span>}
              </footer>
            </article>
          ))}
        </div>
        <div class="testimonial-slider__controls">
          <button class="testimonial-slider__btn" id="testimonial-prev" aria-label="Previous review" type="button">
            <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/></svg>
          </button>
          <div class="testimonial-slider__dots" id="testimonial-dots" role="tablist"></div>
          <button class="testimonial-slider__btn" id="testimonial-next" aria-label="Next review" type="button">
            <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/></svg>
          </button>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═══ SECTION 7: LOCATION & MAP ══════════════ -->
  <section class="location section" aria-labelledby="location-heading">
    <Container>
      <div class="location-grid">
        <div class="location-content">
          <h2 class="section-heading" id="location-heading">Where to Find Us</h2>
          <div class="location-w3w">
            <div class="location-w3w__badge" aria-label="What3Words location">
