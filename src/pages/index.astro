---
import PageLayout from "../layouts/PageLayout.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const allTestimonials = await getCollection("testimonials");
const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);

const facilities = [
  { icon: "shower",    label: "En suite shower & flushing toilet" },
  { icon: "bed",       label: "Bedding, towels & toiletries" },
  { icon: "egg",       label: "Eggs, milk, tea, coffee, oils & more" },
  { icon: "cooking",   label: "Induction hob, microwave, toaster & kettle" },
  { icon: "fridge",    label: "Fridge with ice box" },
  { icon: "usb",       label: "USB charging points" },
  { icon: "fire",      label: "Cosy wood burner" },
  { icon: "firepit",   label: "Kadai fire pit & barbecue" },
  { icon: "music",     label: "Bluetooth radio & board games" },
];

const importantBits = [
  {
    icon: "people",
    title: "Sleeps Two",
    note: "No babies or children",
  },
  {
    icon: "clock",
    title: "Check-in 3pm / Check-out 10am",
    note: "Flexible by arrangement",
  },
  {
    icon: "nopets",
    title: "No Pets",
    note: "Sorry, no exceptions",
  },
];

const galleryImages = [
  { src: "/images/gallery-placeholder-1.jpg", alt: "Interior of Millie The Hut shepherd's hut" },
  { src: "/images/gallery-placeholder-2.jpg", alt: "Countryside views from the private deck" },
  { src: "/images/gallery-placeholder-3.jpg", alt: "Kadai fire pit at dusk" },
];

const faqs = sortedFaqs.length > 0 ? sortedFaqs : [
  { data: { question: "What is there to do near Millie The Hut shepherd's hut in Herefordshire?", answer: "You're perfectly placed for exploring the best of the Welsh Marches. Presteigne is a charming market town just minutes away, while Hay-on-Wye — famous for its bookshops — is a scenic 30-minute drive. Offa's Dyke National Trail passes close by for walkers, and the Brecon Beacons are within easy reach for a day out." }},
  { data: { question: "Is there Wi-Fi at the shepherd's hut?", answer: "Millie The Hut is intentionally off-grid in spirit — we find the best breaks involve disconnecting a little. That said, mobile signal is available and our Bluetooth radio will keep you entertained. We encourage you to swap the scroll for a stroll." }},
  { data: { question: "Is there parking at the glamping site?", answer: "Yes, there is private off-road parking directly at the hut for one vehicle. The location is easily accessible by car from the A44/A4113 corridor." }},
  { data: { question: "What should I pack for a stay at Millie The Hut?", answer: "We supply bedding, towels, toiletries, and a welcome hamper with essentials like eggs, milk, tea and coffee. We recommend packing weather-appropriate clothing (it's the Welsh Marches — be prepared for anything!), walking boots, and a good book. A torch can be handy for evening stargazing." }},
  { data: { question: "Can I have a fire at the glamping hut?", answer: "Absolutely — it's one of the highlights. The Kadai fire pit and barbecue are yours to enjoy, and the wood burner inside keeps the hut beautifully warm on cooler evenings. Logs and kindling are provided." }},
  { data: { question: "How do I find Millie The Hut? Is it easy to locate in the countryside?", answer: "We're located at Wegnall's Mill, Presteigne, Powys, LD8 2LD. The easiest way to find us is with What3Words: ///unwanted.passports.among — just enter this into the What3Words app and it will guide you right to the door. Full arrival instructions are sent with your booking confirmation." }},
];
---

<PageLayout
  title="Millie The Hut | Shepherd's Hut Glamping in the Welsh Marches, Herefordshire"
  description="Escape to Millie The Hut — a beautifully appointed shepherd's hut nestled in the Welsh Marches near Presteigne. Luxury glamping for two with a wood burner, fire pit & stunning countryside views."
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- ═══════════════════════════════════════════════
       SECTION 1: HERO
  ═══════════════════════════════════════════════ -->
  <section class="hero" aria-label="Welcome to Millie The Hut">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/images/hero.avif"
        alt="Millie The Hut shepherd's hut at golden hour in the Welsh Marches countryside"
        class="hero__img"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__body">
      <p class="hero__tagline">Escape to the Welsh Marches.</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 2: INTRODUCTION
  ═══════════════════════════════════════════════ -->
  <section class="intro section" aria-labelledby="intro-heading">
    <Container>
      <h2 class="intro__heading" id="intro-heading">
        Millie The Hut,<br />Presteigne, Herefordshire.
      </h2>

      <p class="intro__text" id="intro-animated-text" aria-label="Tucked away on the England Wales border, Millie The Hut is a lovingly restored shepherd's hut offering a genuine escape from the everyday. Slow mornings with birdsong. Evenings by the fire pit under a sky full of stars. No itinerary. No agenda. Just the kind of rest you've been meaning to have.">
        Tucked away on the England&#8202;/&#8202;Wales border, Millie The Hut is a lovingly restored shepherd's hut offering a genuine escape from the everyday. Slow mornings with birdsong. Evenings by the fire pit under a sky full of stars. No itinerary. No agenda. Just the kind of rest you've been meaning to have.
      </p>

      <!-- Trust Bar -->
      <div class="trust-bar" aria-label="Awards and features">
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="19" stroke="#e3977b" stroke-width="1.5"/>
              <path d="M20 10l2.9 6 6.6.96-4.75 4.63 1.12 6.54L20 25.1l-5.87 3.08 1.12-6.54L10.5 17l6.6-.96L20 10z" fill="#e3977b"/>
            </svg>
          </div>
          <p class="trust-bar__label">Luxury Glamping<br /><span>Welsh Marches</span></p>
        </div>
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="6" y="8" width="28" height="24" rx="3" stroke="#e3977b" stroke-width="1.5"/>
              <path d="M14 20h12M14 25h8" stroke="#e3977b" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="15" r="3" stroke="#e3977b" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="trust-bar__label">Guests Rate Us<br /><span>5 Stars</span></p>
        </div>
        <div class="trust-bar__item">
          <div class="trust-bar__logo" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 6C13.37 6 8 11.37 8 18c0 9 12 22 12 22s12-13 12-22c0-6.63-5.37-12-12-12z" stroke="#e3977b" stroke-width="1.5"/>
              <circle cx="20" cy="18" r="4" stroke="#e3977b" stroke-width="1.5"/>
            </svg>
          </div>
          <p class="trust-bar__label">Near Presteigne<br /><span>Powys, Wales</span></p>
        </div>
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 3: GALLERY PREVIEW
  ═══════════════════════════════════════════════ -->
  <section class="gallery-preview section" aria-labelledby="gallery-heading">
    <Container>
      <div class="gallery-collage">
        <!-- Left: Portrait -->
        <div class="gallery-collage__left">
          <div class="gallery-collage__img-wrap gallery-collage__img-wrap--portrait">
            <div class="gallery-collage__placeholder" aria-label="Interior of Millie The Hut">
              <span>Interior</span>
            </div>
          </div>
        </div>
        <!-- Right: Two Landscape stacked -->
        <div class="gallery-collage__right">
          <div class="gallery-collage__img-wrap gallery-collage__img-wrap--landscape">
            <div class="gallery-collage__placeholder" aria-label="The private deck with countryside views">
              <span>The Deck</span>
            </div>
          </div>
          <div class="gallery-collage__img-wrap gallery-collage__img-wrap--landscape">
            <div class="gallery-collage__placeholder" aria-label="Evening fire pit at Millie The Hut">
              <span>Fire Pit</span>
            </div>
          </div>
        </div>
      </div>
      <div class="gallery-preview__action">
        <a href="/gallery/" class="btn-outline-dark">
          View All Photos
          <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/>
          </svg>
        </a>
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 4: FACILITIES
  ═══════════════════════════════════════════════ -->
  <section class="facilities section section--surface" aria-labelledby="facilities-heading">
    <Container>
      <h2 class="section-heading" id="facilities-heading">Our Facilities</h2>
      <div class="facilities-grid">
        {facilities.map((item) => (
          <div class="facility-card">
            <div class="facility-card__icon" aria-hidden="true">
              {item.icon === "shower" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M208,136H111.51l99.82-99.82a8,8,0,0,0-11.32-11.32L99.52,125.45a95.91,95.91,0,0,0-53.2-29.14,8,8,0,0,0-2.64,15.78A80,80,0,0,1,128,192v8a8,8,0,0,0,16,0v-8h64a8,8,0,0,0,0-16ZM80,200a8,8,0,1,1-8-8A8,8,0,0,1,80,200Zm-32,0a8,8,0,1,1-8-8A8,8,0,0,1,48,200Zm16-28a8,8,0,1,1-8-8A8,8,0,0,1,64,172Z"/></svg>
              )}
              {item.icon === "bed" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M235.58,128.86,211.31,74.69A16,16,0,0,0,196.69,64H59.31A16,16,0,0,0,44.69,74.69L20.42,128.86A8.06,8.06,0,0,0,20,131.2V208a8,8,0,0,0,16,0v-8H220v8a8,8,0,0,0,16,0V131.2A8.06,8.06,0,0,0,235.58,128.86ZM59.31,80H196.69l20,45.71L59.31,80ZM220,184H36V144H220Z"/></svg>
              )}
              {item.icon === "egg" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24C74.82,24,32,80.1,32,148a96,96,0,0,0,192,0C224,80.1,181.18,24,128,24Zm0,176a80,80,0,0,1-80-80c0-59.71,35.75-108,80-108s80,48.29,80,108A80,80,0,0,1,128,200Z"/></svg>
              )}
              {item.icon === "cooking" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M80,40a8,8,0,0,0-8,8V96a48,48,0,0,0,40,47.32V224H80a8,8,0,0,0,0,16h96a8,8,0,0,0,0-16H144V143.32A48,48,0,0,0,184,96V48a8,8,0,0,0-8-8ZM88,96V56h80V96a32,32,0,0,1-64,0ZM40,48a8,8,0,0,1,16,0v96a8,8,0,0,1-16,0Z"/></svg>
              )}
              {item.icon === "fridge" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M176,16H80A24,24,0,0,0,56,40V216a24,24,0,0,0,24,24h96a24,24,0,0,0,24-24V40A24,24,0,0,0,176,16Zm8,200a8,8,0,0,1-8,8H80a8,8,0,0,1-8-8V136H184Zm0-96H72V40a8,8,0,0,1,8-8h96a8,8,0,0,1,8,8ZM120,76V60a8,8,0,0,1,16,0V76a8,8,0,0,1-16,0Zm0,104v-16a8,8,0,0,1,16,0v16a8,8,0,0,1-16,0Z"/></svg>
              )}
              {item.icon === "usb" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M222.59,134.59l-40,40A8,8,0,0,1,171.31,163l16.35-16.35L152,107.31V208a8,8,0,0,1-16,0V107.31L100.34,146.65,116.69,163A8,8,0,0,1,105.41,174.59l-40-40a8,8,0,0,1,0-11.32l40-40A8,8,0,0,1,116.69,95l-16.35,16.34L136,150.69V40a8,8,0,0,1,16,0V150.69l35.66-39.34L171.31,95a8,8,0,0,1,11.28-11.28l40,40A8,8,0,0,1,222.59,134.59Z"/></svg>
              )}
              {item.icon === "fire" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M173.88,103.27C169,90.66,158.26,79.42,141.57,68.43a8,8,0,0,0-11.06,2.31,76.61,76.61,0,0,1-10.68,13.15c-5.15,5.16-8.43,4-9.09,3.66-3.89-2.15-6.72-11.16-4.8-28.11a8,8,0,0,0-12.59-7.43C80.47,62.78,40,98.06,40,152a88,88,0,0,0,176,0C216,133.79,197.27,112.16,173.88,103.27Z"/></svg>
              )}
              {item.icon === "firepit" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M253.66,133.66l-16,16a8,8,0,0,1-11.32-11.32L234.69,130H175.21l-28,96H216a8,8,0,0,1,0,16H40a8,8,0,0,1,0-16H108.79l-28-96H21.31l8.35,8.34a8,8,0,0,1-11.32,11.32l-16-16a8,8,0,0,1,0-11.32l16-16a8,8,0,0,1,11.32,11.32L21.31,114H81.51L67.68,64H48a8,8,0,0,1,0-16H208a8,8,0,0,1,0,16H188.32L174.49,114h60.2l-8.35-8.34a8,8,0,0,1,11.32-11.32l16,16A8,8,0,0,1,253.66,133.66Z"/></svg>
              )}
              {item.icon === "music" && (
                <svg width="28" height="28" viewBox="0 0 256 256" fill="currentColor"><path d="M212.92,25.55a8,8,0,0,0-6.86-1.45l-128,32A8,8,0,0,0,72,64V176a36,36,0,1,0,16,30V120.43l112-28V136a36,36,0,1,0,16,30V32A8,8,0,0,0,212.92,25.55ZM52,228a20,20,0,1,1,20-20A20,20,0,0,1,52,228Zm128-32a20,20,0,1,1,20-20A20,20,0,0,1,180,196ZM88,103.57V69.83l112-28v33.74Z"/></svg>
              )}
            </div>
            <p class="facility-card__label">{item.label}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 5: THE IMPORTANT BITS
  ═══════════════════════════════════════════════ -->
  <section class="important section" aria-labelledby="important-heading">
    <Container>
      <h2 class="section-heading--small" id="important-heading">The Important Bits</h2>
      <div class="important-grid">
        {importantBits.map((bit) => (
          <div class="important-item">
            <div class="important-item__icon" aria-hidden="true">
              {bit.icon === "people" && (
                <svg width="40" height="40" viewBox="0 0 256 256" fill="currentColor"><path d="M244.8,150.4a8,8,0,0,1-11.2-1.6A51.6,51.6,0,0,0,192,128a8,8,0,0,1-7.37-4.89,8,8,0,0,1,1.1-8.33A24,24,0,1,0,150.92,88h0a8,8,0,0,1-16,0h0a40,40,0,1,1,68.19,28.09A67.72,67.72,0,0,1,220,128,51.6,51.6,0,0,1,246.4,161.6,8,8,0,0,1,244.8,150.4ZM190,212a8,8,0,0,1-8,8H74a8,8,0,0,1-8-8,64,64,0,0,1,128,0Zm-16.33,0a48,48,0,0,0-91.34,0ZM128,152a40,40,0,1,0-40-40A40,40,0,0,0,128,152Zm0-64a24,24,0,1,1-24,24A24,24,0,0,1,128,88ZM72,128a8,8,0,0,0-8-8A51.6,51.6,0,0,0,22.4,148.8a8,8,0,1,0,12.8,9.6A35.72,35.72,0,0,1,64,144,8,8,0,0,0,72,128Z"/></svg>
              )}
              {bit.icon === "clock" && (
                <svg width="40" height="40" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm64-88a8,8,0,0,1-8,8H128a8,8,0,0,1-8-8V72a8,8,0,0,1,16,0v48h48A8,8,0,0,1,192,128Z"/></svg>
              )}
              {bit.icon === "nopets" && (
                <svg width="40" height="40" viewBox="0 0 256 256" fill="currentColor"><path d="M213.92,210.62l-160-176A8,8,0,1,0,42.08,45.38L68.9,75.09A64,64,0,0,0,53.5,168.67l-9.41,18.82A8,8,0,0,0,51.29,199a7.6,7.6,0,0,0,3.6.86,8,8,0,0,0,7.18-4.43l8-16a63.49,63.49,0,0,0,58,0l8,16A8,8,0,0,0,143.11,200a7.6,7.6,0,0,0,3.6-.86,8,8,0,0,0,3.58-10.74l-9.18-18.35a64.15,64.15,0,0,0,17.48-13.15l44.49,49A8,8,0,0,0,208,208a8,8,0,0,0,5.92-13.38ZM128,184a48,48,0,0,1-47.61-54l74.62,82.15A47.75,47.75,0,0,1,128,184Zm19.07-86.85a8,8,0,1,1,3.86-15.51c8.42,2.1,15.07,7,19.79,14.61a8,8,0,0,1-13.6,8.4C155.22,101.22,152.15,98.43,147.07,97.15ZM189,66.26a8,8,0,0,1-11.13-2.15c-4.67-7-11-11.56-18.35-13.41a8,8,0,0,1,3.92-15.51C175.1,38.78,184.68,45.3,191.15,55.13A8,8,0,0,1,189,66.26ZM82.59,55.39A8,8,0,0,1,97.7,49.07c3.92,6.19,10.17,10.31,18.59,12.24A8,8,0,1,1,112.64,77C100,74.1,90.14,67.13,82.59,55.39Z"/></svg>
              )}
            </div>
            <h3 class="important-item__title">{bit.title}</h3>
            <p class="important-item__note">{bit.note}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 6: TESTIMONIALS SLIDER
  ═══════════════════════════════════════════════ -->
  <section class="testimonials section section--surface" aria-labelledby="reviews-heading">
    <Container>
      <h2 class="section-heading" id="reviews-heading">Words From Our Guests</h2>

      {allTestimonials.length > 0 ? (
        <div class="testimonial-slider" role="region" aria-label="Guest testimonials">
          <div class="testimonial-slider__track" id="testimonial-track">
            {allTestimonials.map((t, i) => (
              <article class="testimonial-slide" id={`slide-${i}`} aria-hidden={i > 0 ? "true" : "false"}>
                <div class="testimonial-slide__stars" aria-label={`${t.data.rating} out of 5 stars`}>
                  {"★".repeat(t.data.rating)}{"☆".repeat(5 - t.data.rating)}
                </div>
                <blockquote class="testimonial-slide__quote" data-full={t.data.body}>
                  <p class="testimonial-slide__text">{t.data.body}</p>
                </blockquote>
                <footer class="testimonial-slide__footer">
                  <strong class="testimonial-slide__name">{t.data.name}</strong>
                  {t.data.location && <span class="testimonial-slide__location">{t.data.location}</span>}
                </footer>
              </article>
            ))}
          </div>
          <div class="testimonial-slider__controls">
            <button class="testimonial-slider__btn" id="testimonial-prev" aria-label="Previous review" type="button">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/></svg>
            </button>
            <div class="testimonial-slider__dots" id="testimonial-dots" role="tablist"></div>
            <button class="testimonial-slider__btn" id="testimonial-next" aria-label="Next review" type="button">
              <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/></svg>
            </button>
          </div>
        </div>
      ) : (
        <div class="testimonial-placeholder">
          <div class="testimonial-slide">
            <div class="testimonial-slide__stars" aria-label="5 out of 5 stars">★★★★★</div>
            <blockquote class="testimonial-slide__quote">
              <p class="testimonial-slide__text">"Millie The Hut is simply magical. We arrived to a perfectly set hut, lit the fire pit as the sun went down, and didn't want to leave. The most restorative weekend we've had in years."</p>
            </blockquote>
            <footer class="testimonial-slide__footer">
              <strong class="testimonial-slide__name">Sarah & James</strong>
              <span class="testimonial-slide__location">Hereford</span>
            </footer>
          </div>
          <p class="testimonial-placeholder__cta">Add guest reviews via the CMS to display them here.</p>
        </div>
      )}
    </Container>
  </section>

  <!-- ═══════════════════════════════════════════════
       SECTION 7: LOCATION & MAP
