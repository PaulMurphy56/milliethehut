<script is:inline>
  // ─── Testimonial Slider ───
  (function () {
    var slider = document.getElementById("testimonial-slider");
    if (!slider) return;

    var slides = slider.querySelectorAll(".testimonials__slide");
    var dots = slider.querySelectorAll(".testimonials__dot");
    var current = 0;
    var total = slides.length;

    function goTo(index) {
      slides[current].classList.remove("is-active");
      dots[current].classList.remove("is-active");
      dots[current].setAttribute("aria-selected", "false");
      current = (index + total) % total;
      slides[current].classList.add("is-active");
      dots[current].classList.add("is-active");
      dots[current].setAttribute("aria-selected", "true");
    }

    slider.querySelector("[data-dir='prev']").addEventListener("click", function () {
      goTo(current - 1);
    });

    slider.querySelector("[data-dir='next']").addEventListener("click", function () {
      goTo(current + 1);
    });

    dots.forEach(function (dot, i) {
      dot.addEventListener("click", function () { goTo(i); });
    });

    // Truncation
    var MAX_CHARS = 220;
    slides.forEach(function (slide) {
      var textEl = slide.querySelector(".testimonials__text");
      if (!textEl) return;
      var full = textEl.textContent;
      if (full.length > MAX_CHARS) {
        var truncated = full.substring(0, MAX_CHARS);
        textEl.setAttribute("data-full", full);
        textEl.textContent = truncated;
        textEl.classList.add("is-truncated");

        var btn = document.createElement("button");
        btn.className = "testimonials__view-more";
        btn.textContent = "View more";
        btn.type = "button";
        textEl.parentNode.appendChild(btn);

        btn.addEventListener("click", function () {
          var showing = btn.textContent === "View less";
          textEl.textContent = showing ? truncated : full;
          textEl.classList.toggle("is-truncated", showing);
          btn.textContent = showing ? "View more" : "View less";
        });
      }
    });
  })();

  // ─── Scroll Text Reveal ───
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    var el = document.getElementById("scroll-text");
    if (!el) return;
    var p = el.querySelector("p");
    if (!p) return;

    var text = p.textContent;
    var words = text.split(/(\s+)/);
    p.innerHTML = "";
    var spans = [];

    words.forEach(function (word) {
      if (word.match(/^\s+$/)) {
        p.appendChild(document.createTextNode(word));
      } else {
        var span = document.createElement("span");
        span.textContent = word;
        span.style.color = "#cccccc";
        span.style.transition = "color 0.3s ease";
        p.appendChild(span);
        spans.push(span);
      }
    });

    function updateColors() {
      var rect = el.getBoundingClientRect();
      var windowH = window.innerHeight;
      var elTop = rect.top;
      var elH = rect.height;

      // Progress: 0 when element enters viewport, 1 when center of element reaches center of viewport
      var progress = Math.max(0, Math.min(1, (windowH - elTop) / (windowH * 0.5 + elH * 0.5)));

      var revealCount = Math.floor(progress * spans.length);
      spans.forEach(function (span, i) {
        span.style.color = i < revealCount ? "#000000" : "#cccccc";
      });
    }

    var ticking = false;
    window.addEventListener("scroll", function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          updateColors();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateColors();
  })();
</script>
