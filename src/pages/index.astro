</style>

<script is:inline>
  // ─── Testimonial Arrow Scroll ───
  (function () {
    var scrollContainer = document.getElementById("testimonials-scroll");
    var nextBtn = document.getElementById("testimonials-next");
    if (!scrollContainer || !nextBtn) return;

    nextBtn.addEventListener("click", function () {
      var cards = scrollContainer.querySelectorAll(".review-card");
      if (!cards.length) return;
      var cardWidth = cards[0].offsetWidth + 24; // card width + gap
      scrollContainer.scrollBy({ left: cardWidth, behavior: "smooth" });
    });
  })();

  // ─── Review Card Read More Toggle ───
  (function () {
    document.querySelectorAll(".review-card").forEach(function (card) {
      var textEl = card.querySelector(".review-card__text");
      var btn = card.querySelector(".review-card__toggle");
      if (!textEl || !btn) return;

      if (textEl.scrollHeight > textEl.clientHeight) {
        btn.style.display = "block";
      }

      btn.addEventListener("click", function () {
        var expanded = textEl.classList.toggle("review-card__text--expanded");
        btn.textContent = expanded ? "Show less" : "Read more";
        btn.setAttribute("aria-expanded", String(expanded));
      });
    });
  })();

  // ─── Scroll Text Reveal ───
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    var el = document.getElementById("scroll-text");
    if (!el) return;
    var p = el.querySelector("p");
    if (!p) return;

    var text = p.textContent;
    var words = text.split(/(\s+)/);
    p.innerHTML = "";
    var spans = [];

    words.forEach(function (word) {
      if (word.match(/^\s+$/)) {
        p.appendChild(document.createTextNode(word));
      } else {
        var span = document.createElement("span");
        span.textContent = word;
        span.style.color = "#cccccc";
        span.style.transition = "color 0.3s ease";
        p.appendChild(span);
        spans.push(span);
      }
    });

    function updateColors() {
      var rect = el.getBoundingClientRect();
      var windowH = window.innerHeight;
      var elTop = rect.top;

      // Animation triggers when text is 15% down the page
      var triggerTop = windowH * 0.85;
      var triggerEnd = windowH * 0.15;
      var progress = Math.max(0, Math.min(1, (triggerTop - elTop) / (triggerTop - triggerEnd)));

      var revealCount = Math.floor(progress * spans.length);
      spans.forEach(function (span, i) {
        span.style.color = i < revealCount ? "#000000" : "#cccccc";
      });
    }

    var ticking = false;
    window.addEventListener("scroll", function () {
      if (!ticking) {
        requestAnimationFrame(function () {
          updateColors();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateColors();
  })();

  // ─── Line Divider Animation ───
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    var dividers = document.querySelectorAll("[data-line-divider]");
    if (!dividers.length) return;

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          observer.unobserve(el);
          setTimeout(function () {
            el.classList.add("is-animating");
          }, 1500);
        }
      });
    }, { threshold: 0.1 });

    dividers.forEach(function (d) { observer.observe(d); });
  })();
</script>
