---
import PageLayout from "../layouts/PageLayout.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { siteConfig } from "../lib/siteConfig";
import { getCollection, render } from "astro:content";

const allGallery = await getCollection("gallery");
const sortedGallery = allGallery.sort((a, b) => a.data.order - b.data.order);

const allTestimonials = await getCollection("testimonials");
const testimonialData = await Promise.all(
  allTestimonials.map(async (t) => {
    const { Content } = await render(t);
    return { ...t, Content };
  })
);

const allAmenities = await getCollection("amenities");
const sortedAmenities = allAmenities.sort((a, b) => a.data.order - b.data.order);

const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);

const homepageSettingsCollection = await getCollection("homepageSettings");
const homepageSettings = homepageSettingsCollection[0]?.data;

const avatarColors = ["#b5533c", "#7a9e7e", "#9a4232", "#5a7a5e"];
---

<PageLayout
  title={`${siteConfig.name} | Shepherd's Hut Glamping near Presteigne, Wales`}
  description="Millie The Hut — a beautifully restored shepherd's hut on the England/Wales border near Presteigne. Book your countryside glamping escape today."
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <Container>
      <div class="hero__inner">
        <div class="hero__content" data-reveal="slide-up">
          <p class="hero__eyebrow">Presteigne, Powys</p>
          <h1 class="hero__title" id="hero-heading">
            {homepageSettings?.headline || "Your Countryside Escape Awaits"}
          </h1>
          <p class="hero__subtitle">
            {homepageSettings?.subheadline || "A beautifully restored shepherd's hut nestled on the England/Wales border. Slow down, breathe deep, and let the hills hold you."}
          </p>
          <div class="hero__actions">
            <Button href="/book/" size="lg">Book Your Stay</Button>
            <Button href="/the-hut/" variant="outline" size="lg">Discover the Hut</Button>
          </div>
        </div>
        <div class="hero__visual" data-reveal="fade" aria-hidden="true">
          {homepageSettings?.heroImage ? (
            <img
              src={homepageSettings.heroImage}
              alt={homepageSettings.heroImageAlt || "Millie The Hut shepherd's hut exterior"}
              class="hero__image"
            />
          ) : (
            <div class="hero__image-placeholder">
              <span class="hero__placeholder-text">Millie The Hut</span>
              <span class="hero__placeholder-sub">Add your hero photo via the CMS</span>
            </div>
          )}
        </div>
      </div>
    </Container>

    <!-- Key facts strip -->
    <div class="hero__facts">
      <Container>
        <ul class="hero__facts-list" role="list" data-reveal-stagger>
          <li class="hero__fact"><strong>2 guests max</strong></li>
          <li class="hero__fact"><strong>2-night minimum</strong></li>
          <li class="hero__fact"><strong>Dogs welcome</strong></li>
          <li class="hero__fact"><strong>Check-in from 3pm</strong></li>
        </ul>
      </Container>
    </div>
  </section>

  <!-- Features / About teaser -->
  <section class="section" aria-labelledby="about-heading">
    <Container>
      <div class="about-grid">
        <div class="about__content" data-reveal="slide-up">
          <SectionHeading
            label="About the Hut"
            title="A tiny hut, an enormous escape"
            description="Millie is a lovingly restored shepherd's hut sitting quietly on the England/Wales border, surrounded by the rolling hills of the Welsh Marches. Inside, everything is thoughtfully designed for two."
          />
          <Button href="/the-hut/">Explore the Hut</Button>
        </div>
        <div class="amenities-grid" data-reveal-stagger>
          {sortedAmenities.slice(0, 6).map((amenity) => (
            <div class="amenity-card">
              <h3 class="amenity-card__title">{amenity.data.title}</h3>
              <p class="amenity-card__desc">{amenity.data.description}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- Gallery strip -->
  <section class="gallery-section" aria-labelledby="gallery-heading">
    <Container>
      <SectionHeading
        label="Gallery"
        title="Life at Millie"
        align="center"
      />
    </Container>
    <div class="gallery" data-reveal="fade">
      <button class="gallery__arrow gallery__arrow--prev" type="button" aria-label="Previous slide">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/></svg>
      </button>
      <div class="gallery__track-wrapper">
        <div class="gallery__track">
          {sortedGallery.map((img) => (
            <div class="gallery__slide">
              <div class="gallery__placeholder" role="img" aria-label={img.data.alt}>
                <span class="gallery__placeholder-label">{img.data.title}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button class="gallery__arrow gallery__arrow--next" type="button" aria-label="Next slide">
        <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true"><path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/></svg>
      </button>
    </div>
    <Container>
      <div class="gallery__dots" role="tablist" aria-label="Gallery slides"></div>
    </Container>
  </section>

  <!-- Testimonials -->
  <section class="section section--surface" aria-labelledby="testimonials-heading">
    <Container>
      <SectionHeading
        label="Guest Reviews"
        title="Words from our guests"
        align="center"
      />
      <div class="testimonials-grid" data-reveal-stagger>
        {testimonialData.map((t, i) => (
          <article class="testimonial-card">
            <div class="testimonial__stars" aria-label={`${t.data.rating} out of 5 stars`}>
              {"★".repeat(t.data.rating)}
            </div>
            <blockquote class="testimonial__body">
              <t.Content />
            </blockquote>
            <footer class="testimonial__footer">
              <div
                class="testimonial__avatar"
                style={`background: ${avatarColors[i % avatarColors.length]}`}
                aria-hidden="true"
              >
                {t.data.name.charAt(0)}
              </div>
              <div class="testimonial__info">
                <strong class="testimonial__name">{t.data.name}</strong>
                <span class="testimonial__location">{t.data.location}</span>
              </div>
            </footer>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- FAQs -->
  <section class="section" aria-labelledby="faq-heading">
    <Container narrow>
      <SectionHeading
        label="FAQs"
        title="Good to know"
        align="center"
      />
      <div class="faq-list" data-reveal-stagger>
        {sortedFaqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-item__question">{faq.data.question}</summary>
            <p class="faq-item__answer">{faq.data.answer}</p>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner" aria-labelledby="cta-heading">
    <Container>
      <div class="cta-banner__inner" data-reveal="slide-up">
        <h2 class="cta-banner__title" id="cta-heading">Ready to escape?</h2>
        <p class="cta-banner__desc">Check availability and book your stay at Millie The Hut. We'd love to welcome you.</p>
        <div class="cta-banner__actions">
          <Button href="/book/" size="lg">Book Now</Button>
          <Button href={`mailto:${siteConfig.email}`} variant="outline" size="lg">Get in Touch</Button>
        </div>
      </div>
    </Container>
  </section>
</PageLayout>

<style>
  /* ========== Hero ========== */
  .hero {
    background: var(--color-surface);
    padding-top: var(--space-5xl);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: center;
    padding-bottom: var(--section-padding);
  }

  .hero__eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    max-width: none;
  }

  .hero__title {
    margin-bottom: var(--space-lg);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2xl);
    max-width: 40ch;
    font-style: italic;
    font-family: var(--font-serif);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .hero__visual {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-text-inverse);
    padding: var(--space-xl);
    text-align: center;
  }

  .hero__placeholder-text {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
  }

  .hero__placeholder-sub {
    font-size: var(--text-sm);
    opacity: 0.7;
  }

  /* Key facts strip */
  .hero__facts {
    background: var(--color-primary);
    padding: var(--space-lg) 0;
  }

  .hero__facts-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl);
    justify-content: center;
  }

  .hero__fact {
    color: var(--color-text-inverse);
    font-size: var(--text-sm);
  }

  /* ========== Sections ========== */
  .section {
    padding: var(--section-padding) 0;
  }

  .section--surface {
    background: var(--color-surface);
  }

  /* ========== About / Amenities grid ========== */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .amenity-card {
    padding: var(--space-lg);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
  }

  .amenity-card__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-xs);
    font-family: var(--font-sans);
  }

  .amenity-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: none;
  }

  /* ========== Gallery ========== */
  .gallery-section {
    padding: var(--section-padding) 0;
    overflow: hidden;
  }

  .gallery {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0 var(--container-padding);
    margin-bottom: var(--space-md);
  }

  .gallery__track-wrapper {
    overflow: hidden;
    border-radius: var(--radius-2xl);
    flex: 1;
  }

  .gallery__track {
    display: flex;
    transition: transform 0.5s var(--ease-in-out);
    touch-action: pan-y;
    cursor: grab;
  }

  .gallery__track.is-dragging {
    cursor: grabbing;
    transition: none;
  }

  .gallery__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .gallery__placeholder {
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--color-surface-alt) 0%, var(--color-surface) 100%);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .gallery__placeholder-label {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-style: italic;
  }

  .gallery__arrow {
    display: none;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .gallery__arrow:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .gallery__dots {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .gallery__dots :global(.gallery__dot) {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .gallery__dots :global(.gallery__dot.is-active) {
    background: var(--color-primary);
  }

  /* ========== Testimonials ========== */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  .testimonial-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .testimonial__stars {
    color: var(--color-primary);
    font-size: var(--text-base);
    letter-spacing: 2px;
  }

  .testimonial__body {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-style: italic;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    flex: 1;
  }

  .testimonial__body :global(p) {
    max-width: none;
  }

  .testimonial__footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .testimonial__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: #fff;
    flex-shrink: 0;
  }

  .testimonial__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial__name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }

  .testimonial__location {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* ========== FAQ ========== */
  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    cursor: pointer;
    list-style: none;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__question::after {
    content: "+";
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: var(--weight-normal);
    color: var(--color-primary);
    flex-shrink: 0;
    margin-left: var(--space-md);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .faq-item[open] .faq-item__question::after {
    content: "\2212";
    transform: rotate(180deg);
  }

  .faq-item__answer {
    padding-bottom: var(--space-lg);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  /* ========== CTA Banner ========== */
  .cta-banner {
    background: var(--color-text);
    color: var(--color-text-inverse);
    padding: var(--section-padding) 0;
  }

  .cta-banner__inner {
    text-align: center;
  }

  .cta-banner__title {
    color: var(--color-text-inverse);
    margin-bottom: var(--space-md);
  }

  .cta-banner__desc {
    font-size: var(--text-lg);
    opacity: 0.8;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
    font-family: var(--font-serif);
    font-style: italic;
    max-width: 48ch;
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }

  .cta-banner__actions :global(.btn--outline) {
    border-color: rgba(250, 247, 242, 0.4);
    color: var(--color-text-inverse);
  }

  .cta-banner__actions :global(.btn--outline:hover) {
    border-color: var(--color-text-inverse);
  }

  /* ========== Responsive ========== */
  @media (min-width: 48rem) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery__arrow {
      display: flex;
    }
  }

  @media (min-width: 64rem) {
    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4xl);
    }

    .about-grid {
      grid-template-columns: 1fr 1.2fr;
    }

    .amenities-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script is:inline>
  // Gallery slider
  (function () {
    const track = document.querySelector(".gallery__track");
    const dotsContainer = document.querySelector(".gallery__dots");
    const prevBtn = document.querySelector(".gallery__arrow--prev");
    const nextBtn = document.querySelector(".gallery__arrow--next");
    if (!track || !dotsContainer) return;

    const slides = track.querySelectorAll(".gallery__slide");
    let current = 0;
    const total = slides.length;

    slides.forEach(function (_, i) {
      var dot = document.createElement("button");
      dot.className = "gallery__dot" + (i === 0 ? " is-active" : "");
      dot.setAttribute("role", "tab");
      dot.setAttribute("aria-label", "Slide " + (i + 1));
      dot.addEventListener("click", function () { goTo(i); });
      dotsContainer.appendChild(dot);
    });

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      current = index;
      var slideWidth = track.parentElement.offsetWidth;
      track.style.transform = "translateX(-" + (current * slideWidth) + "px)";
      dotsContainer.querySelectorAll(".gallery__dot").forEach(function (d, i) {
        d.classList.toggle("is-active", i === current);
      });
    }

    if (prevBtn) prevBtn.addEventListener("click", function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener("click", function () { goTo(current + 1); });

    var startX = 0, isDragging = false, movedX = 0;
    var wrapper = track.parentElement;

    wrapper.addEventListener("touchstart", function (e) { startX = e.touches[0].clientX; isDragging = true; movedX = 0; }, { passive: true });
    wrapper.addEventListener("touchmove", function (e) { if (!isDragging) return; movedX = e.touches[0].clientX - startX; }, { passive: true });
    wrapper.addEventListener("touchend", function () {
      if (!isDragging) return;
      isDragging = false;
      if (movedX > 50) goTo(current - 1);
      else if (movedX < -50) goTo(current + 1);
      movedX = 0;
    });
    wrapper.addEventListener("touchcancel", function () { isDragging = false; movedX = 0; });
    track.addEventListener("mousedown", function (e) { startX = e.clientX; isDragging = true; track.classList.add("is-dragging"); e.preventDefault(); });
    document.addEventListener("mousemove", function (e) { if (!isDragging) return; movedX = e.clientX - startX; });
    document.addEventListener("mouseup", function () {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove("is-dragging");
      if (movedX > 50) goTo(current - 1);
      else if (movedX < -50) goTo(current + 1);
      movedX = 0;
    });
  })();
</script>
