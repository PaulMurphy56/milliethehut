---
import PageLayout from "../layouts/PageLayout.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import Container from "../components/ui/Container.astro";
import { getCollection } from "astro:content";

const allTestimonials = await getCollection("testimonials");
const allFaqs = await getCollection("faqs");
const sortedFaqs = allFaqs.sort((a, b) => a.data.order - b.data.order);

const siteSettingsCollection = await getCollection("siteSettings");
const site = siteSettingsCollection[0]?.data;
---

<PageLayout
  title="Millie The Hut | Shepherd's Hut Glamping in the Welsh Marches, Herefordshire"
  description="Escape to Millie The Hut — a beautifully appointed shepherd's hut nestled in the Welsh Marches near Presteigne. Luxury glamping for two with a wood burner, fire pit & stunning countryside views."
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <h1 class="sr-only">Millie The Hut — Shepherd's Hut Glamping in the Welsh Marches</h1>

  <!-- Hero -->
  <section class="hero" aria-label="Hero">
    <div class="hero__frame">
      <img
        src="/images/hero.avif"
        alt="Millie The Hut shepherd's hut at golden hour in the Welsh Marches countryside"
        class="hero__img"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero__overlay">
        <div class="hero__overlay-top"></div>
        <p class="hero__tagline">Escape to the<br />Welsh Marches</p>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section section--white" aria-labelledby="intro-heading">
    <Container narrow>
      <div class="intro">
        <h2 class="intro__heading" id="intro-heading">Millie The Hut, Presteigne, Herefordshire.</h2>
        <div class="intro__text" id="scroll-text">
          <p>Down a leafy lane, where steam trains once ran, across a Victorian railway bridge that takes you from Wales to England, you'll find a meadow where sheep graze, and a traditional-style Shepherds Hut and Shack. On sunny days, the meadow is bathed in light from dawn to dusk, and the gin-clear Hindwell Brook that bounds it flashes silver. Whatever the weather, after dark is a special time to be here, when the log burner in the hut, the firepit by the stream and the lamps and candles in the Shack cast a magical golden glow.</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Trust Indicators -->
  <section class="section section--white section--tight-top" aria-labelledby="trust-heading">
    <Container>
      <h2 class="sr-only" id="trust-heading">Why Choose Millie The Hut</h2>
      <div class="trust" data-reveal-stagger>
        <div class="trust__item">
          <img class="trust__img trust__img--bg-remove" src="/images/i.jpg" alt="Independent award — one of the best 25 budget glamping sites in the UK" width="150" height="150" loading="lazy" decoding="async" />
          <p class="trust__label">One of the best 25 'budget' glamping sites in the UK</p>
        </div>
        <div class="trust__item">
          <img class="trust__img" src="/images/dt.png" alt="Distinctly Norfolk award logo" width="150" height="150" loading="lazy" decoding="async" />
          <p class="trust__label">"Remarkably affordable.... excellent choice"</p>
        </div>
        <div class="trust__item">
          <img class="trust__img" src="/images/luxlife.png" alt="Lux Life award logo" width="150" height="150" loading="lazy" decoding="async" />
          <p class="trust__label">Best Shepherds Hut UK 2025</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Animated Line Divider -->
  <div class="section--white">
    <Container>
      <div class="line-divider" data-line-divider></div>
    </Container>
  </div>

  <!-- Gallery Preview -->
  <section class="section section--white" aria-labelledby="gallery-heading">
    <Container>
      <h2 class="section__heading" id="gallery-heading">Gallery</h2>
      <div class="gallery-preview" data-reveal="fade">
        <div class="gallery-preview__left">
          <div class="gallery-preview__img-wrap gallery-preview__img-wrap--portrait">
            <img src="/images/stars.avif" alt="Starry night sky over Millie The Hut in the Welsh Marches" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="gallery-preview__right">
          <div class="gallery-preview__img-wrap">
            <img src="/images/bbq.jpg" alt="Kadai fire pit and barbecue at Millie The Hut" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
          <div class="gallery-preview__img-wrap">
            <img src="/images/drone.jpg" alt="Aerial view of Millie The Hut and surrounding countryside" class="gallery-preview__img" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
      <div class="gallery-preview__cta">
        <a href="/gallery/" class="btn">View All <span class="btn__arrow">&rarr;</span></a>
      </div>
    </Container>
  </section>

  <!-- Animated Line Divider -->
  <div class="section--cream">
    <Container>
      <div class="line-divider" data-line-divider></div>
    </Container>
  </div>

  <!-- Facilities -->
  <section class="section section--cream" aria-labelledby="facilities-heading">
    <Container>
      <h2 class="section__heading" id="facilities-heading">The Facilities</h2>
      <ul class="facilities" data-reveal-stagger>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M64,236a12,12,0,1,1-12-12A12,12,0,0,1,64,236Zm20-44a12,12,0,1,0,12,12A12,12,0,0,0,84,192Zm-64,0a12,12,0,1,0,12,12A12,12,0,0,0,20,192Zm32-32a12,12,0,1,0,12,12A12,12,0,0,0,52,160ZM248,32H216a8,8,0,0,0-5.66,2.34l-30.2,30.2L53.38,86.19a16,16,0,0,0-8.69,27.1l98,98a16,16,0,0,0,27.09-8.66L191.46,75.86,219.31,48H248a8,8,0,0,0,0-16Z"/></svg>
          <span>En suite shower &amp; flushing toilet</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M224,48V152a8,8,0,0,1-8.53,8,8.17,8.17,0,0,1-7.47-8.25V48a8,8,0,0,0-8.55-8A8.19,8.19,0,0,0,192,48.28V180a4,4,0,0,1-4,4H52a4,4,0,0,1-4-4V48A24,24,0,0,1,72,24H200A24,24,0,0,1,224,48ZM188,200H52a4,4,0,0,0-4,4v12a16,16,0,0,0,16,16H176a16,16,0,0,0,16-16V204A4,4,0,0,0,188,200Z"/></svg>
          <span>Bedding, towels &amp; toiletries</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M208,80H32a8,8,0,0,0-8,8v48a96.3,96.3,0,0,0,32.54,72H32a8,8,0,0,0,0,16H208a8,8,0,0,0,0-16H183.46a96.59,96.59,0,0,0,27-40.09A40,40,0,0,0,248,128v-8A40,40,0,0,0,208,80Zm24,48a24,24,0,0,1-17.2,23,95.78,95.78,0,0,0,1.2-15V97.38A24,24,0,0,1,232,120ZM112,56V24a8,8,0,0,1,16,0V56a8,8,0,0,1-16,0Zm32,0V24a8,8,0,0,1,16,0V56a8,8,0,0,1-16,0ZM80,56V24a8,8,0,0,1,16,0V56a8,8,0,0,1-16,0Z"/></svg>
          <span>Eggs, milk, tea, coffee, oils etc</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M208,32H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32ZM172,56a12,12,0,1,1-12,12A12,12,0,0,1,172,56Zm-44,0a12,12,0,1,1-12,12A12,12,0,0,1,128,56ZM84,56A12,12,0,1,1,72,68,12,12,0,0,1,84,56ZM192,192H64V104H192Z"/></svg>
          <span>Induction hob, microwave, toaster, kettle</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M192,24H64A24,24,0,0,0,40,48V208a24,24,0,0,0,24,24H192a24,24,0,0,0,24-24V48A24,24,0,0,0,192,24ZM160,72H96a8,8,0,0,1,0-16h64a8,8,0,0,1,0,16Z"/></svg>
          <span>Fridge with ice box</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M224,56H176V16a8,8,0,0,0-16,0V56H96V16a8,8,0,0,0-8-8c-3.21,0-8,2.27-8,8.54V56H32.55C26.28,56,24,60.78,24,64a8,8,0,0,0,8,8H48v88a40,40,0,0,0,40,40h32v40a8,8,0,0,0,16,0V200h32a40,40,0,0,0,40-40V72h16a8,8,0,0,0,0-16Zm-72.51,74.81-12,32a8,8,0,0,1-15-5.62l8-21.19H112a8,8,0,0,1-7.49-10.81l12-32a8,8,0,1,1,15,5.62l-8,21.19H144a8,8,0,0,1,7.49,10.81Z"/></svg>
          <span>USB points</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M143.38,17.85a8,8,0,0,0-12.63,3.41l-22,60.41L84.59,58.26a8,8,0,0,0-11.93.89C51,87.53,40,116.08,40,144a88,88,0,0,0,176,0C216,84.55,165.21,36,143.38,17.85Zm40.51,135.49a57.6,57.6,0,0,1-46.56,46.55A7.65,7.65,0,0,1,136,200a8,8,0,0,1-1.32-15.89c16.57-2.79,30.63-16.85,33.44-33.45a8,8,0,0,1,15.78,2.68Z"/></svg>
          <span>Wood burner</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M132.19,25.19a8,8,0,0,0-8.38,0A156,156,0,0,0,96.24,48C77.77,67.13,68,87.9,68,108a60,60,0,0,0,120,0C188,60.08,134.47,26.59,132.19,25.19ZM128,152a24,24,0,0,1-24-24c0-24,24-40,24-40s24,16,24,40A24,24,0,0,1,128,152Zm95.62,74.42a8,8,0,0,1-10.05,5.2L128,204.39,42.43,231.62a8,8,0,1,1-4.85-15.25l64-20.37-64-20.38a8,8,0,1,1,4.85-15.24L128,187.6l85.57-27.22a8,8,0,1,1,4.85,15.24l-64,20.38,64,20.37A8,8,0,0,1,223.62,226.42Z"/></svg>
          <span>Kadai fire pit &amp; barbecue</span>
        </li>
        <li class="facilities__item">
          <svg class="facilities__icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 256 256" fill="currentColor"><path d="M200,176a8,8,0,0,1-3.2,6.4l-64,48A8,8,0,0,1,128,232a8,8,0,0,1-8-8V144L68.8,182.4a8,8,0,0,1-9.6-12.8L114.67,128,59.2,86.4a8,8,0,0,1,9.6-12.8L120,112V32a8,8,0,0,1,12.8-6.4l64,48a8,8,0,0,1,0,12.8L141.33,128l55.47,41.6A8,8,0,0,1,200,176Z"/></svg>
          <span>Bluetooth radio &amp; board games</span>
        </li>
      </ul>
    </Container>
  </section>

  <!-- Animated Line Divider -->
  <div class="section--cream">
    <Container>
      <div class="line-divider" data-line-divider></div>
    </Container>
  </div>

  <!-- The Essentials -->
  <section class="section section--cream" aria-labelledby="essentials-heading">
    <Container>
      <h2 class="section__heading" id="essentials-heading">The Essentials</h2>
      <div class="essentials" data-reveal-stagger>
        <div class="essentials__item">
          <svg class="essentials__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M164.47,195.63a8,8,0,0,1-6.7,12.37H10.23a8,8,0,0,1-6.7-12.37,95.83,95.83,0,0,1,47.22-37.71,60,60,0,1,1,66.5,0A95.83,95.83,0,0,1,164.47,195.63Zm87.91-.15a95.87,95.87,0,0,0-47.13-37.56A60,60,0,0,0,144.7,54.59a4,4,0,0,0-1.33,6A75.83,75.83,0,0,1,147,150.53a4,4,0,0,0,1.07,5.53,112.32,112.32,0,0,1,29.85,30.83,23.92,23.92,0,0,1,3.65,16.47,4,4,0,0,0,3.95,4.64h60.3a8,8,0,0,0,7.73-5.93A8.22,8.22,0,0,0,252.38,195.48Z"/></svg>
          <p class="essentials__label"><strong>Sleeps Two</strong></p>
          <p class="essentials__sub">No babies or children</p>
        </div>
        <div class="essentials__item">
          <svg class="essentials__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm56,112H128a8,8,0,0,1-8-8V72a8,8,0,0,1,16,0v48h48a8,8,0,0,1,0,16Z"/></svg>
          <p class="essentials__label"><strong>Check in times:</strong></p>
          <p class="essentials__sub">In: 3pm | Out: 10am</p>
        </div>
        <div class="essentials__item">
          <svg class="essentials__icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 256 256" fill="currentColor"><path d="M240,108a28,28,0,1,1-28-28A28,28,0,0,1,240,108ZM72,108a28,28,0,1,0-28,28A28,28,0,0,0,72,108ZM92,88A28,28,0,1,0,64,60,28,28,0,0,0,92,88Zm72,0a28,28,0,1,0-28-28A28,28,0,0,0,164,88Zm23.12,60.86a35.3,35.3,0,0,1-16.87-21.14,44,44,0,0,0-84.5,0A35.25,35.25,0,0,1,69,148.82,40,40,0,0,0,88,224a39.48,39.48,0,0,0,15.52-3.13,64.09,64.09,0,0,1,48.87,0,40,40,0,0,0,34.73-72Z"/></svg>
          <p class="essentials__label"><strong>No Pets</strong></p>
          <p class="essentials__sub">Sorry!</p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Testimonials -->
  <section class="section section--white" aria-labelledby="testimonials-heading">
    <Container>
      <h2 class="section__heading" id="testimonials-heading">What Our Guests Say</h2>
      <div class="testimonials-wrap">
        <div class="testimonials-scroll" id="testimonials-scroll">
          {allTestimonials.length > 0 ? (
            allTestimonials.map((t) => (
              <blockquote class="review-card">
                <span class="review-card__quote" aria-hidden="true">&ldquo;</span>
                <p class="review-card__text">{t.body}</p>
                <button class="review-card__toggle" type="button" aria-expanded="false">Read more</button>
                <footer class="review-card__footer">
                  <span class="review-card__name">{t.data.name}</span>
                  <span class="review-card__date">{t.data.date}</span>
                </footer>
              </blockquote>
            ))
          ) : (
            <>
              <blockquote class="review-card">
                <span class="review-card__quote" aria-hidden="true">&ldquo;</span>
                <p class="review-card__text">The most magical place we've ever stayed. Waking up to the sound of the brook and the sheep grazing in the meadow was absolutely heavenly. The hut has everything you need and more — we didn't want to leave.</p>
                <button class="review-card__toggle" type="button" aria-expanded="false">Read more</button>
                <footer class="review-card__footer">
                  <span class="review-card__name">Sarah &amp; James</span>
                  <span class="review-card__date">February 2026</span>
                </footer>
              </blockquote>
              <blockquote class="review-card">
                <span class="review-card__quote" aria-hidden="true">&ldquo;</span>
                <p class="review-card__text">A truly special retreat. The attention to detail is extraordinary — from the wood burner to the fire pit by the stream, every moment felt considered. The perfect escape from city life.</p>
                <button class="review-card__toggle" type="button" aria-expanded="false">Read more</button>
                <footer class="review-card__footer">
                  <span class="review-card__name">Emily</span>
                  <span class="review-card__date">January 2026</span>
                </footer>
              </blockquote>
            </>
          )}
        </div>
        <button class="testimonials-arrow" type="button" aria-label="Scroll to next review" id="testimonials-next">
          &rarr;
        </button>
      </div>
    </Container>
  </section>

  <!-- Location & Map -->
  <section class="section section--white" aria-labelledby="location-heading">
    <Container>
      <h2 class="section__heading" id="location-heading">Where to Find Us</h2>
      <div class="location">
        <div class="location__info">
          <div class="location__w3w">
            <h3 class="location__sub-heading">What3Words</h3>
            <p class="location__words">///unwanted.passports.among</p>
            <p class="location__w3w-explain">What3Words divides the world into 3m squares, each with a unique three-word address. Use it for accurate navigation directly to Millie The Hut.</p>
          </div>
          <address class="location__address">
            Wegnall's Mill<br />
            Presteigne<br />
            Powys<br />
            LD8 2LD
          </address>
        </div>
        <div class="location__map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d2500!2d-2.995298!3d52.261831!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2suk"
            width="100%"
            height="400"
            style="border:0; border-radius: var(--radius-xl);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map showing location of Millie The Hut near Presteigne, Powys"
          ></iframe>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <section class="section section--cream" aria-labelledby="faq-heading">
    <Container narrow>
      <h2 class="section__heading" id="faq-heading">Frequently Asked Questions</h2>
      <div class="faq">
        {sortedFaqs.length > 0 ? (
          sortedFaqs.map((faq) => (
            <details class="faq__item">
              <summary class="faq__question">{faq.data.question}</summary>
              <p class="faq__answer" set:html={faq.data.answer}></p>
            </details>
          ))
        ) : (
          <>
            <details class="faq__item">
              <summary class="faq__question">What should I pack for a Shepherd's Hut stay in the Welsh Marches?</summary>
              <p class="faq__answer">We provide bedding, towels and toiletries so you can travel light. We'd recommend bringing walking boots or wellies, warm layers for evenings by the fire pit, and a torch. Everything else you need — from tea and coffee to cooking essentials — is already here waiting for you.</p>
            </details>
            <details class="faq__item">
              <summary class="faq__question">Is there Wi-Fi at the shepherd's hut?</summary>
              <p class="faq__answer">There is no Wi-Fi at Millie The Hut — and that's by design. This is a place to disconnect and recharge. Mobile signal varies by network but is generally available. We find most guests welcome the chance to switch off.</p>
            </details>
            <details class="faq__item">
              <summary class="faq__question">Is parking available at the glamping site?</summary>
              <p class="faq__answer">Yes, free private parking is available right next to the hut. You can unload directly from your car before parking up for your stay.</p>
            </details>
            <details class="faq__item">
              <summary class="faq__question">Is the shepherd's hut suitable for a winter stay?</summary>
              <p class="faq__answer">Absolutely. The wood burner keeps the hut beautifully warm and cosy, making winter one of the most magical times to visit. There's nothing quite like cosying up by the fire while frost sparkles on the meadow outside.</p>
            </details>
            <details class="faq__item">
              <summary class="faq__question">Are there pubs, restaurants or walks nearby?</summary>
              <p class="faq__answer">Presteigne is just a short drive away and has excellent pubs, cafés and an award-winning independent cinema. The surrounding countryside offers stunning walks along Offa's Dyke, through the Radnorshire hills, and along the River Lugg. We provide a local guide with all our favourite recommendations.</p>
            </details>
            <details class="faq__item">
              <summary class="faq__question">How do I find Millie The Hut using What3Words?</summary>
              <p class="faq__answer">Our What3Words address is ///unwanted.passports.among. Simply enter this into the What3Words app or website and it will navigate you directly to within three metres of the hut entrance. It's the most accurate way to find us down our leafy lane.</p>
            </details>
          </>
        )}
      </div>
    </Container>
  </section>

</PageLayout>

<style>
  /* ─── Section Backgrounds ─── */
  .section--cream {
    background-color: var(--color-bg);
  }
  .section--white {
    background-color: var(--color-bg-white);
  }

  /* ─── Animated Line Divider ─── */
  .line-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.15);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 1.2s var(--ease-out);
  }
  .line-divider.is-animating {
    transform: scaleX(1);
  }

  /* ─── Hero ─── */
  .hero {
    min-height: 100vh;
    padding: var(--hero-padding);
    display: flex;
  }

  .hero__frame {
    position: relative;
    flex: 1;
    border-radius: var(--radius-hero);
    overflow: hidden;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .hero__overlay {
