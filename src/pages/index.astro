    color: var(--color-text-muted); line-height: var(--leading-relaxed);
  }
  .location-address p { max-width: none; }
  .location-map {
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-lg);
    background: var(--color-surface-alt);
  }
  .location-map iframe { width: 100%; height: 100%; display: block; }

  /* ── FAQ ──────────────────────────────────── */
  .faq-list { max-width: 720px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid var(--color-border-light); }
  .faq-item:first-child { border-top: 1px solid var(--color-border-light); }
  .faq-item__question {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-md);
    width: 100%; padding: var(--space-lg) 0; background: none; border: none; cursor: pointer;
    text-align: left; font-family: var(--font-serif); font-size: var(--text-lg);
    font-weight: var(--weight-bold); color: var(--color-text); line-height: var(--leading-snug);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .faq-item__question:hover { color: var(--color-primary); }
  .faq-item__icon {
    display: flex; align-items: center; flex-shrink: 0; width: 20px; height: 20px;
    color: var(--color-primary); transition: transform var(--duration-fast) var(--ease-out);
  }
  .faq-icon-plus { display: block; }
  .faq-icon-minus { display: none; }
  .faq-item--open .faq-icon-plus { display: none; }
  .faq-item--open .faq-icon-minus { display: block; }
  .faq-item__answer {
    max-height: 0; overflow: hidden;
    transition: max-height var(--duration-slow) var(--ease-out), padding var(--duration-normal) var(--ease-out);
  }
  .faq-item__answer p {
    padding-bottom: var(--space-lg); font-size: var(--text-base); color: var(--color-text-muted);
    line-height: var(--leading-relaxed); max-width: none;
  }

  /* ── Responsive ───────────────────────────── */
  @media (min-width: 40rem) {
    .important-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 48rem) {
    .facilities-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 64rem) {
    .hero-nav { display: flex; }
    .hero-menu-btn { display: none; }
    .location-grid { grid-template-columns: 1fr 1.1fr; }
    .gallery-collage { aspect-ratio: 16 / 9; }
  }
</style>

<script is:inline>
  (function () {

    /* ── Hero mobile menu → opens global mobile-nav ── */
    var heroMenuBtn = document.querySelector(".hero-menu-btn");
    var mobileNav = document.getElementById("mobile-nav");
    if (heroMenuBtn && mobileNav) {
      function closeMenu() {
        heroMenuBtn.setAttribute("aria-expanded", "false");
        mobileNav.classList.remove("is-open");
        document.body.style.overflow = "";
      }
      heroMenuBtn.addEventListener("click", function () {
        var expanded = heroMenuBtn.getAttribute("aria-expanded") === "true";
        heroMenuBtn.setAttribute("aria-expanded", String(!expanded));
        mobileNav.classList.toggle("is-open");
        document.body.style.overflow = expanded ? "" : "hidden";
      });
      mobileNav.addEventListener("click", function (e) {
        if (e.target.tagName === "A") closeMenu();
      });
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") closeMenu();
      });
    }

    /* ── Line-by-line scroll animation ── */
    var textEl = document.getElementById("intro-animated-text");
    if (textEl && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      var raw = textEl.textContent.trim();
      var words = raw.split(/\s+/);
      textEl.innerHTML = words.map(function (w) {
        return '<span class="word">' + w + '</span>';
      }).join(" ");

      var wordEls = textEl.querySelectorAll(".word");
      var total = wordEls.length;

      // Group words by their visual line (offsetTop)
      var lines = [];
      var lastTop = -1;
      wordEls.forEach(function (w) {
        var top = w.getBoundingClientRect().top + window.scrollY;
        if (Math.abs(top - lastTop) > 4) {
          lines.push([]);
          lastTop = top;
        }
        lines[lines.length - 1].push(w);
      });
      var totalLines = lines.length;

      function updateWords() {
        var rect = textEl.getBoundingClientRect();
        var viewH = window.innerHeight;
        var start = viewH;
        var end = viewH * 0.5 - rect.height * 0.5;
        var progress = Math.min(1, Math.max(0, (start - rect.top) / (start - end)));
        var litLines = Math.round(progress * totalLines);
        lines.forEach(function (line, i) {
          line.forEach(function (w) {
            w.classList.toggle("is-lit", i < litLines);
          });
        });
      }

      window.addEventListener("scroll", updateWords, { passive: true });
      window.addEventListener("resize", function () {
        // Recompute lines on resize
        lines = [];
        lastTop = -1;
        wordEls.forEach(function (w) {
          var top = w.getBoundingClientRect().top + window.scrollY;
          if (Math.abs(top - lastTop) > 4) {
            lines.push([]);
            lastTop = top;
          }
          lines[lines.length - 1].push(w);
        });
        totalLines = lines.length;
        updateWords();
      });
      updateWords();
    }

    /* ── Testimonial slider ── */
    var slides = document.querySelectorAll(".testimonial-slide");
    var dotsContainer = document.getElementById("testimonial-dots");
    var prevBtn = document.getElementById("testimonial-prev");
    var nextBtn = document.getElementById("testimonial-next");

    if (slides.length > 0 && dotsContainer) {
      var current = 0;
      var dots = [];

      slides.forEach(function (slide, i) {
        var textEl = slide.querySelector(".testimonial-slide__text");
        if (textEl && textEl.textContent.length > 300) {
          textEl.classList.add("is-truncated");
          var btn = document.createElement("button");
          btn.className = "testimonial-slide__read-more";
          btn.textContent = "Read More";
          btn.addEventListener("click", function () {
            var expanded = textEl.classList.toggle("is-truncated");
            btn.textContent = expanded ? "Read More" : "Show Less";
          });
          textEl.insertAdjacentElement("afterend", btn);
        }

        var dot = document.createElement("button");
        dot.className = "testimonial-dot" + (i === 0 ? " is-active" : "");
        dot.setAttribute("role", "tab");
        dot.setAttribute("aria-label", "Review " + (i + 1));
        dot.addEventListener("click", function () { goTo(i); });
        dotsContainer.appendChild(dot);
        dots.push(dot);
      });

      function goTo(index) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;
        slides[current].classList.remove("is-active");
        slides[current].setAttribute("aria-hidden", "true");
        dots[current].classList.remove("is-active");
        current = index;
        slides[current].classList.add("is-active");
        slides[current].setAttribute("aria-hidden", "false");
        dots[current].classList.add("is-active");
      }

      goTo(0);

      if (prevBtn) prevBtn.addEventListener("click", function () { goTo(current - 1); });
      if (nextBtn) nextBtn.addEventListener("click", function () { goTo(current + 1); });

      var timer = setInterval(function () { goTo(current + 1); }, 6000);
      var sliderEl = document.querySelector(".testimonial-slider");
      if (sliderEl) {
        sliderEl.addEventListener("mouseenter", function () { clearInterval(timer); });
        sliderEl.addEventListener("mouseleave", function () {
          timer = setInterval(function () { goTo(current + 1); }, 6000);
        });
      }
    }

    /* ── FAQ accordion ── */
    document.querySelectorAll(".faq-item__question").forEach(function (btn) {
      var answer = document.getElementById(btn.getAttribute("aria-controls"));
      btn.addEventListener("click", function () {
        var item = btn.closest(".faq-item");
        var isOpen = item.classList.contains("faq-item--open");
        document.querySelectorAll(".faq-item--open").forEach(function (openItem) {
          openItem.classList.remove("faq-item--open");
          var a = openItem.querySelector(".faq-item__answer");
          var b = openItem.querySelector(".faq-item__question");
          if (a) a.style.maxHeight = null;
          if (b) b.setAttribute("aria-expanded", "false");
        });
        if (!isOpen && answer) {
          item.classList.add("faq-item--open");
          btn.setAttribute("aria-expanded", "true");
          answer.style.maxHeight = answer.scrollHeight + "px";
        }
      });
    });

  })();
</script>
