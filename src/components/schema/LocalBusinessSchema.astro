---
import { getCollection } from "astro:content";

const siteSettingsCollection = await getCollection("siteSettings");
const site = siteSettingsCollection[0]?.data;
if (!site) return;
---

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    name: site.name,
    description: site.description,
    url: "https://milliethehut.co.uk",
    telephone: site.phone,
    email: site.email,
    address: {
      "@type": "PostalAddress",
      addressLocality: site.addressLocality,
      addressRegion: site.addressRegion,
      postalCode: site.addressPostalCode,
      addressCountry: site.addressCountry,
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: site.geoLatitude,
      longitude: site.geoLongitude,
    },
    checkinTime: site.checkinTime,
    checkoutTime: site.checkoutTime,
    amenityFeature: [
      { "@type": "LocationFeatureSpecification", name: "Wood-burning stove", value: true },
      { "@type": "LocationFeatureSpecification", name: "Private deck", value: true },
      { "@type": "LocationFeatureSpecification", name: "Countryside views", value: true },
    ],
    sameAs: [site.instagramUrl, site.facebookUrl].filter(Boolean),
    priceRange: "££",
  })}
/>
