---
import { getCollection } from "astro:content";
import Container from "../ui/Container.astro";

const siteSettingsCollection = await getCollection("siteSettings");
const site = siteSettingsCollection[0]?.data;

const nav = [
  { label: "Gallery", href: "/gallery/" },
  { label: "Local Area", href: "/location/" },
  { label: "Your Hosts", href: "/your-hosts/" },
  { label: "Contact", href: "/contact/" },
];
---

<header class="header" role="banner" id="site-header">
  <Container>
    <div class="header__inner">
      <a href="/" class="header__logo" aria-label="Millie The Hut — Home">
        <span class="header__logo-text">{site?.name ?? "Millie The Hut"}</span>
      </a>

      <nav class="header__nav" aria-label="Main navigation">
        <ul class="header__nav-list" role="list">
          {nav.map((item) => (
            <li>
              <a href={item.href} class="header__nav-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header__actions">
        <a href={site?.bookingUrl ?? "/book/"} class="header__book-btn" aria-label="Book Now">
          <span>Book Now</span>
          <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/>
          </svg>
        </a>
      </div>

      <button
        class="header__menu-btn"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="header__menu-icon"></span>
      </button>
    </div>
  </Container>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    transition: background var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  /* Transparent over hero */
  .header.is-transparent {
    background: transparent;
  }

  /* Scrolled / non-hero pages */
  .header.is-solid,
  .header:not(.is-transparent) {
    background: rgba(244, 243, 239, 0.85);
    backdrop-filter: blur(16px) saturate(1.8);
    -webkit-backdrop-filter: blur(16px) saturate(1.8);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
  }

  .header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .header__logo-text {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-white);
    letter-spacing: -0.01em;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .header.is-solid .header__logo-text,
  .header:not(.is-transparent) .header__logo-text {
    color: var(--color-text);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .header__nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    padding: var(--space-sm) 0;
    display: inline-block;
    transition: color var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .header__nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-white);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .header__nav-link:hover::after {
    transform: scaleX(1);
  }

  .header.is-solid .header__nav-link,
  .header:not(.is-transparent) .header__nav-link {
    color: var(--color-text);
  }

  .header.is-solid .header__nav-link::after,
  .header:not(.is-transparent) .header__nav-link::after {
    background: var(--color-text);
  }

  .header__actions {
    display: none;
    align-items: center;
  }

  .header__book-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: var(--color-cta);
    color: var(--color-black);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    transition:
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
    white-space: nowrap;
  }

  .header__book-btn:hover {
    background: var(--color-cta-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(171, 227, 196, 0.4);
  }

  .header__book-btn svg {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .header__book-btn:hover svg {
    transform: translateX(3px);
  }

  .header__menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header__menu-icon,
  .header__menu-icon::before,
  .header__menu-icon::after {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--color-white);
    border-radius: 1px;
    transition: all var(--duration-normal) var(--ease-out);
    position: relative;
  }

  .header.is-solid .header__menu-icon,
  .header.is-solid .header__menu-icon::before,
  .header.is-solid .header__menu-icon::after,
  .header:not(.is-transparent) .header__menu-icon,
  .header:not(.is-transparent) .header__menu-icon::before,
  .header:not(.is-transparent) .header__menu-icon::after {
    background: var(--color-text);
  }

  .header__menu-icon::before,
  .header__menu-icon::after {
    content: "";
    position: absolute;
    left: 0;
  }

  .header__menu-icon::before { top: -6px; }
  .header__menu-icon::after { top: 6px; }

  .header__menu-btn[aria-expanded="true"] .header__menu-icon {
    background: transparent;
  }
  .header__menu-btn[aria-expanded="true"] .header__menu-icon::before {
    top: 0;
    transform: rotate(45deg);
  }
  .header__menu-btn[aria-expanded="true"] .header__menu-icon::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (min-width: 64rem) {
    .header__nav { display: block; }
    .header__actions { display: flex; }
    .header__menu-btn { display: none; }
  }
</style>

<script is:inline>
  (function () {
    var header = document.getElementById("site-header");
    var hero = document.querySelector(".hero");
    if (!header) return;

    function update() {
      var scrolled = window.scrollY > 20;
      if (hero) {
        // On hero page: transparent over hero, solid once scrolled past
        var heroBottom = hero.offsetHeight;
        if (window.scrollY > heroBottom - 80) {
          header.classList.remove("is-transparent");
          header.classList.add("is-solid");
        } else {
          header.classList.add("is-transparent");
          header.classList.remove("is-solid");
        }
      } else {
        header.classList.remove("is-transparent");
        header.classList.add("is-solid");
      }
    }

    update();
    window.addEventListener("scroll", update, { passive: true });

    // Mobile menu
    var btn = document.querySelector(".header__menu-btn");
    var nav = document.getElementById("mobile-nav");
    if (!btn || !nav) return;

    function closeMenu() {
      btn.setAttribute("aria-expanded", "false");
      nav.classList.remove("is-open");
      document.body.style.overflow = "";
    }

    btn.addEventListener("click", function () {
      var expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("is-open");
      document.body.style.overflow = expanded ? "" : "hidden";
    });

    nav.addEventListener("click", function (e) {
      if (e.target.tagName === "A") closeMenu();
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeMenu();
    });
  })();
</script>
