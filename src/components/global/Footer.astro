---
import { siteConfig } from "../../lib/siteConfig";
import Container from "../ui/Container.astro";
---

<footer class="footer" role="contentinfo">
  <Container>
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="footer__logo">{siteConfig.name}</span>
        <p class="footer__tagline">{siteConfig.tagline}</p>
        <p class="footer__address">
          {siteConfig.address.locality}, {siteConfig.address.region}
        </p>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Explore</h3>
        <ul class="footer__links" role="list">
          <li><a href="/">Home</a></li>
          <li><a href="/the-hut/">The Hut</a></li>
          <li><a href="/location/">Location</a></li>
          <li><a href="/book/">Book & Contact</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Contact</h3>
        <ul class="footer__links" role="list">
          <li><a href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}>{siteConfig.phone}</a></li>
          <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        </ul>
        <div class="footer__socials">
          {Object.entries(siteConfig.socials).map(([platform, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer" aria-label={`Follow us on ${platform}`} class="footer__social-link">
              {platform.charAt(0).toUpperCase() + platform.slice(1)}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: var(--color-text-inverse);
    padding: var(--section-padding) 0 var(--space-2xl);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .footer__logo {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    opacity: 0.75;
    margin-bottom: var(--space-md);
    font-style: italic;
    font-family: var(--font-serif);
    max-width: 30ch;
  }

  .footer__address {
    font-size: var(--text-sm);
    opacity: 0.6;
    line-height: var(--leading-relaxed);
  }

  .footer__heading {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
    opacity: 0.5;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__links a {
    font-size: var(--text-sm);
    opacity: 0.8;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .footer__links a:hover {
    opacity: 1;
  }

  .footer__socials {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .footer__social-link {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .footer__social-link:hover {
    opacity: 1;
  }

  .footer__bottom {
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(250, 247, 242, 0.12);
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    opacity: 0.4;
  }

  @media (min-width: 48rem) {
    .footer__grid {
      grid-template-columns: 1.75fr 1fr 1fr;
    }
  }
</style>
